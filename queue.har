            "text": "define(\"clientSettings\", [], function () {\n\tvar settings = {\n\t\taddBodyClasses: {\n\t\t\tenabled: true,\n\t\t\t\"display-competition-crest\": false, // Display the competition crest on events\n\t\t\t\"display-availability\": false, // Display the availability of the event\n\t\t\t\"display-points-in-header\": false, // Display loyalty points in the header\n\t\t\t\"display-full-image-hospitality-packages\": false, // Display full image for hospitality packages\n\t\t\t\"display-user-icon\": true, // Display the user icon in the header\n\t\t\t\"display-basket-icon\": true, // Display the basket icon in the header\n\t\t\t\"display-basket-subtitles\": true, // Display the basket subtitles\n\t\t\t\"force-basket-assign-owner\": true, // Assign owner\n\t\t\t\"disable-renewal-price\": true, // Disable renewal price\n\t\t\t\"disable-dont-renew\": false, // Disable don't renew\n\t\t\t\"flip-seats\": false, // Flip seat icons, if seats are displaying facing the wrong direction\n\t\t\t\"disable-print-confirmation\": true, // Hide the print confirmation button\n\t\t\t\"enable-filter-spinner\": true, // Enable the filter spinner\n\t\t\t\"display-choose-seats-for-me\": true, // Display the choose seats for me button\n\t\t\t\"display-remove-all\": false, // Display the remove all button in the basket\n\t\t\t\"display-basket-summary\": true, // Display the basket summary on checkout\n\t\t\t\"disable-not-renew\": false, // Disable the not renew button\n\t\t\t\"desktop-ecrm-grid-as-cards\": true, // Display the desktop ecrm grid as cards\n\t\t\t\"display-next-event-icons\": true, // Display the next event icons\n\t\t\t\"display-sticky-basket-timer\": false, // Display the sticky basket timer\n\t\t\t\"display-memberships-list\": true, // Display the memberships list\n\t\t\t\"display-subscriptions-list\": true, // Display the subscriptions list\n\t\t\t\"useSROColours\": false, // Use SRO colours\n\t\t\t\"display-expanded-basket-summary\": true, // Display the expanded basket summary\n\t\t},\n\n\t\thideUnavailablePackages: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Add a hospitality prompt on the area selection (html)\n\t\thospitalityUpsell: {\n\t\t\tenabled: true,\n\t\t\tcontent:\n\t\t\t\t\"<a href='/hospitality'>Click here</a> to view our hospitality packages\",\n\t\t},\n\n\t\t// Add a message at the top of the ticket selection\n\t\tnonSeatedMessage: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t\"\",\n\t\t\teventName: \"tour\",\n\t\t},\n\n\t\t// Seperate password reset page\n\t\tpasswordReset: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Next match landing page panel\n\t\tnextMatch: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Display stadium key (html)\n\t\tdisplayStadiumKey: {\n\t\t\tenabled: true,\n\t\t\tcontent:\n\t\t\t\t'<div class=\"leg\"><div class=\"legend available good\"></div><div class=\"description\">Good Availability</div></div><div class=\"leg\"><div class=\"legend available limited\"></div><div class=\"description\">Limited Availability</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div>',\n\t\t},\n\n\t\t// Display seat key (html)\n\t\tdisplaySeatKey: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'<div class=\"leg\"><div class=\"legend available\"></div><div class=\"description\">Available</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div><div class=\"leg\"><div class=\"legend selected\"></div><div class=\"description\">Selected</div></div>',\n\t\t},\n\n\t\t// Replace seat key (html)\n\t\treplaceSeatMessageAndKey: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'',\n\t\t\tkey: '',\n\t\t},\n\n\t\t// Display hospitality package pricing (price label)\n\t\tdisplayHospitalityPricing: {\n\t\t\tenabled: true,\n\t\t\tcontent: \"\",\n\t\t},\n\n\t\t// Hide Available Seat Qty\n\t\thideAvailabilitySeatQty: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Filters for Category Page\n\t\tfiltersForCategoryPage: {\n\t\t\tenabled: false,\n\t\t\tfilterBy: \"Filter by\",\n\t\t\tcompetition: \"Competition\",\n\t\t\tseason: \"Season\",\n\t\t\tdate: \"Date\",\n\t\t\tvenue: \"Venue\",\n\t\t\topposition: \"Opposition\",\n\t\t\treset: \"Reset\",\n\t\t},\n\n\t\t// Auto Expand Area Selection\n\t\tautoExpandAreaSelection: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Promo Box (description, link)\n\t\tpromoBox: {\n\t\t\tenabled: true,\n\t\t\tdescription: \"Do you have a promotion code?\",\n\t\t\tlink: \"I have a promo code\",\n\t\t},\n\n\t\t// Gift Voucher Box (description, link)\n\t\tvoucherBox: {\n\t\t\tenabled: true,\n\t\t\tdescription: \"Do you have a gift voucher?\",\n\t\t\tlink: \"I have a gift voucher\",\n\t\t},\n\n\t\t// Auto Check Assign Owners\n\t\tautoCheckAssignOwners: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Mandatory Ticket Schemes (number of schemes)\n\t\tmandatoryTicketSchemes: {\n\t\t\tenabled: true,\n\t\t\tnumber: 99,\n\t\t},\n\n\t\t// Change Basket Seat Location for Hospitality\n\t\tchangeBasketSeatLocationHospitality: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Hide Subscription List\n\t\thideSubscriptionList: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Hide Memberships List\n\t\thideMembershipsList: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Ballots Terms\n\t\tballotTerms: {\n\t\t\tenabled: true,\n\t\t\tdescription: \"Yes, I have read the\",\n\t\t\tlinkText: \"Ballot Terms & Conditions\",\n\t\t\tlink: \"https://www.liverpoolfc.com/legal/liverpool-football-club-terms-and-conditions\",\n\t\t},\n\n\t\t// Force Basket Login\n\t\tforceBasketLogin: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Force Address Collection\n\t\tforceAddressCollection: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Ticket collection default to email\n\t\tticketCollectionForceDefault: {\n\t\t\tenabled: true,\n\t\t\tdefault: \"load_on_card\",\n\t\t},\n\n\t\tresetFormED: {\n\t\t\tenabled: false,\n\t\t\t$form: $(\"#extraDataForm_name\"),\n\t\t},\n\n\t\t// Remove More Info\n\t\tremoveMoreInfo: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Default Check Ticket Schemes\n\t\tdefaultCheckTicketSchemes: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Seperate Registration Page\n\t\tseperateRegistrationPage: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Hide Seasonal Hospitality Seat\n\t\thideSeasonalHosptialitySeat: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Display Languages\n\t\tdisplayLanguages: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Custom extra data forms function takes an array of form names and/or a bool to say use on all forms\n\t\tcustomDataForm: {\n\t\t\tenabled: true,\n\t\t\tformNames: [\"extraDataForm_ExtraData_CustomForm14\"],\n\t\t\tclearFieldsOnAllForms: true,\n\t\t},\n\n\t\t// Hide Edit Profile for Company Account\n\t\thideEditProfileForCompanyAccount: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Resale Page\n\t\tresalePage: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\t// Resale Welcome Panel\n\t\tresalePanel: {\n\t\t\tenabled: true,\n\t\t\tcontent:\n\t\t\t'<div id=\"resale-welcome-panel\"><h2>Ticket Exchange</h2><div id=\"ticketExchangeContent\" class=\"welcomeContent\">Bought tickets but cannot use them? Click below to sell them<br /><br /><a class=\"landing-button primary\" href=\"resale.aspx\">Return Ticket</a></div></div>',\n\t\t},\n\n\t\t// Direct Click to Dashboard\n\t\teCRMDirect: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Next Event Panel\n\t\tnextEventPanel: {\n\t\t\tenabled: false,\n\t\t\taddOns: false,\n\t\t\tcontent: '<a class=\"next-event-resale\" href=\"resale.aspx\">Cancel Ticket</a>',\n\t\t},\n\n\t\tzeroPayment: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tforwardStrongRelationships: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\tgetDonationDescription: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tgetGiftVoucherImage: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tredirectContinueCategoryVisited: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tcrmMobileScrollTicketButtons: {\n\t\t\tenabled: true,\n\t\t\tshowResale: true,\n\t\t\tforward: {\n\t\t\t\tsmall: \"Forward\",\n\t\t\t\tlarge: \"Forward / Upgrade Ticket\",\n\t\t\t},\n\t\t\tdonate: {\n\t\t\t\tsmall: \"Donate\",\n\t\t\t\tlarge: \"Donate Ticket\",\n\t\t\t},\n\t\t\tdownload: {\n\t\t\t\tsmall: \"Download\",\n\t\t\t\tlarge: \"Add to mobile wallet\",\n\t\t\t},\n\t\t\tresale: {\n\t\t\t\tsmall: \"Resale\",\n\t\t\t\tlarge: \"Resale Tickets\",\n\t\t\t},\n\t\t},\n\n\t\tuseTicketSchemesTerms: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tremoveStrongRelationshipRoles: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tmandatoryTicketSchemesByName: {\n\t\t\tenabled: true,\n\t\t},\n\t\thideElementsPerPage: {\n\t\t\tenabled: false,\n\t\t\telementsPageObject: {\n\t\t\t\t\"\": [\"/memberships\", \"\"]\n\t\t\t}\n\t\t},\n\t\teSROHeaderV2: {\n\t\t\tenabled: true,\n\t\t},\n\n\t};\n\n\treturn settings;\n});\n"
          },
