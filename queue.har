            "size": 35615,
            "mimeType": "application/javascript",
            "text": "(function eSROHeaderV2() {\n  if (!document.getElementById(\"flag-icons-css\")) {\n    var _flagIconsLink = document.createElement(\"link\");\n    _flagIconsLink.id = \"flag-icons-css\";\n    _flagIconsLink.rel = \"stylesheet\";\n    _flagIconsLink.href = \"https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css\";\n    document.head.appendChild(_flagIconsLink);\n  }\n\n  require([\"js/res!/cus/release/js/custom-captions.res\"], function (res) {\n    window.captions = res.Captions;\n\n    var _siteConfigPromise = null;\n\n    function getAcceptLanguageHeader() {\n      var culture = ($eSRO && $eSRO.culture) ? $eSRO.culture : document.documentElement.lang || \"en-GB\";\n      var lang = culture.split(\"-\")[0];\n      return culture + \", \" + lang + \";q=0.9\";\n    }\n\n    function getSiteConfig() {\n      if (!_siteConfigPromise) {\n        _siteConfigPromise = new Promise(function (resolve, reject) {\n          require([\"web-api\"], function (api) {\n            api.call(\"v1.0/security/configuration\", {\n                headers: { \"Accept-Language\": getAcceptLanguageHeader() }\n              })\n              .then(function (result) { resolve(result.data); })\n              .catch(reject);\n          });\n        });\n      }\n      return _siteConfigPromise;\n    }\n\n    params = {\n      enabled: false,\n      desktopToMobileOffset: 380, // Offset for when to switch to mobile menu\n      mobileMenuLocation: \"\", // class or id of the element where mobile menu will be placed after\n      desktopMenuLocation: \"#PH_Menu\", // class or id of the element where desktop menu will be placed after\n      directClick: false, // Direct click to crmdetails/my-account\n      htmlInjection: { html: \"\", location: \"\" }, // HTML to be injected into the header\n      callback: function () {}, // Callback function\n      hideCrmMenu: true,\n      customHeader: false,\n      generateTopBar: true, // Generate top bar from headerMenuConfig.json\n    };\n    // Get the text content from the span element\n    $(\"body\").addClass(\"hide-crm-menu\");\n\n    if ($eSRO.hasClient) {\n      createNewAccountIcon();\n    }\n\n    function onDataReady(data) {\n      $(function () {\n        afterDataFetch(data);\n        params.customHeader && $(\"body\").addClass(\"header-v2-custom\");\n      });\n    }\n\n    if (window.headerMenuConfig) {\n      onDataReady(window.headerMenuConfig);\n    } else {\n      $.getJSON(\"/webapp-assets/headerMenuConfig.json\", function (data) {\n        console.log(\"Data fetched successfully\");\n      })\n        .done(function (data) {\n          onDataReady(data);\n        })\n        .fail(function (err) {\n          console.log(\"Failed to fetch HeaderMenuConfig.json data\", err);\n        });\n    }\n\n    function afterDataFetch(data) {\n      $(\"body\").addClass(\"header-v2\");\n      const mobileLogoLeft = data?.mobileLogoLeft;\n      if (\n        mobileLogoLeft === true ||\n        String(mobileLogoLeft).toLowerCase() === \"true\"\n      ) {\n        $(\"body\").addClass(\"header-v2-mobile-logo-left\");\n      }\n      if (params.generateTopBar) {\n        createTopBar(data);\n        // Styles are now in headerv2.less, no need to inject them dynamically\n      }\n\n      if (data && data.layoutType === \"double\") {\n        $(\"body\").addClass(\"header-v2-double\");\n\n        const setHeaderHeight = () => {\n          const $groupHeaderFixed = $(\"#group_Header-fixed\");\n          if ($groupHeaderFixed.length) {\n            const headerHeight = $groupHeaderFixed.outerHeight();\n            document.documentElement.style.setProperty(\n              \"--group-header-fixed-height\",\n              headerHeight + \"px\",\n            );\n          }\n        };\n\n        if (data.spanningLogo) {\n          $(\"body\").addClass(\"header-v2-spanning-logo\");\n        }\n\n        // Set height immediately and on resize\n        setHeaderHeight();\n        $(window).on(\"resize\", setHeaderHeight);\n      }\n\n      const $desktopMenu = createDesktopMenu(data.items);\n      const $mobileMenu = buildMenuMobile(data.items);\n      replaceUIMenu($desktopMenu, $mobileMenu);\n      buildLinks();\n      if (!params.directClick && $eSRO.hasClient)\n        setupCrmMenu(data.profile_navigation); // Changed from crmHoverMenu\n\n      const mobileBreakpoint = getMobileScreenWidth();\n      console.log(\"Mobile breakpoint: \", mobileBreakpoint);\n      $(window)\n        .resize(function () {\n          onResize(mobileBreakpoint);\n        })\n        .trigger(\"resize\");\n      params.callback();\n    }\n\n    // Helper function to get title with caption priority\n    function getTitleOrCaption(item) {\n      if (\n        item.titleCaption &&\n        window.captions &&\n        window.captions[item.titleCaption]\n      ) {\n        return window.captions[item.titleCaption];\n      }\n      return item.title || \"\";\n    }\n\n    function createTopBar(data) {\n      if (!data) return;\n\n      const hasSecondary =\n        Array.isArray(data.secondaryItems) && data.secondaryItems.length > 0;\n      const hasSponsors =\n        Array.isArray(data.headerSponsors) && data.headerSponsors.length > 0;\n      const isDoubleLayout = data.layoutType === \"double\";\n\n      if (!hasSecondary && !hasSponsors && !isDoubleLayout) return;\n\n      $(\"#PH_HeaderMenuTopBar\").remove();\n      const $topBar = $('<div id=\"PH_HeaderMenuTopBar\" class=\"topBar\"></div>');\n      const $headerFixed = $(\"#group_Header-fixed\");\n\n      const preserveSelectors = [\"#PH_SupportedCultures\"];\n      const $preserved = preserveSelectors.reduce(($acc, sel) => {\n        const $el = $headerFixed.find(sel);\n        if ($el.length) $acc = $acc.add($el.detach());\n        return $acc;\n      }, $());\n\n      if ($headerFixed.length) {\n        $headerFixed.empty();\n        $headerFixed.prepend($topBar);\n        if ($preserved.length) $topBar.append($preserved);\n      } else {\n        $(\"body\").prepend($topBar);\n      }\n\n      const $inner = $('<div class=\"topBar-inner\"></div>');\n      const $secondaryContainer = $('<div class=\"siteMenuContainer\"></div>');\n      const $secondaryMenu = $(\n        '<ul id=\"navMenuSecondary\" class=\"navMenuSecondary\"></ul>',\n      );\n\n      if (Array.isArray(data.secondaryItems)) {\n        data.secondaryItems.forEach((item) => {\n          if (!item || !item.title) return;\n          const href = item.link || \"#\";\n          const isExternal = /^https?:\\/\\//i.test(href);\n          const title = getTitleOrCaption(item);\n          const $link = $(\n            `<a href=\"${href}\"${isExternal ? ' target=\"_self\" rel=\"noopener noreferrer\"' : \"\"}><p>${title}</p></a>`,\n          );\n          const $li = $(\"<li></li>\");\n          $li.append($link);\n          $secondaryMenu.append($li);\n        });\n      }\n\n      if ($secondaryMenu.children().length) {\n        $secondaryContainer.append($secondaryMenu);\n        $inner.append($secondaryContainer);\n      }\n\n      if (Array.isArray(data.headerSponsors) && data.headerSponsors.length) {\n        const $sponsors = $('<div class=\"headerSponsors\"></div>');\n        data.headerSponsors.forEach((sponsor) => {\n          if (!sponsor || !sponsor.imgSrc) return;\n          const href = sponsor.link || \"#\";\n          const isExternal = /^https?:\\/\\//i.test(href);\n          const alt = sponsor.imgAlt || \"\";\n          const $link = $(\n            `<a href=\"${href}\"${isExternal ? ' target=\"_self\" rel=\"noopener noreferrer\"' : \"\"} class=\"headerSponsorLink\"></a>`,\n          );\n          const $img = $(`<img src=\"${sponsor.imgSrc}\" alt=\"${alt}\">`);\n          $link.append($img);\n          $sponsors.append($link);\n        });\n\n        if ($sponsors.children().length) {\n          $inner.append($sponsors);\n        }\n      }\n\n      $topBar.append($inner);\n\n      requirejs.config({\n        paths: {\n          settingsUtil: \"/cus/release/js/settingsUtil\",\n          defaultSettings: \"/cus/release/js/defaultSettings\",\n          clientSettings: \"/usercontent/js/clientSettings\",\n        },\n      });\n      require([\"settingsUtil\"], function (settingsUtil) {\n        var settings = settingsUtil.mergeSettings();\n        if (settings.cultureSelectorTopBar && settings.cultureSelectorTopBar.enabled) {\n          createCultureSelector($inner);\n        }\n      });\n    }\n\n    function getMobileScreenWidth() {\n      let totalWidth = 0;\n      $(\".navbar-nav > li\").each(function () {\n        totalWidth += $(this).outerWidth(true); // Includes margins\n      });\n\n      return totalWidth + params.desktopToMobileOffset;\n    }\n\n    // New function to setup the menu without API call\n    function setupCrmMenu(menuData) {\n      const $myAccount = $(\".flm_myAccount\");\n      let menuLoaded = false;\n\n      $myAccount.attr(\"href\", \"javascript:void(0)\");\n\n      // Create skeleton menu immediately\n      const $crmMenu = createSkeletonMenu(menuData);\n      $myAccount.append($crmMenu);\n\n      $myAccount.click(function () {\n        if (!menuLoaded) {\n          // Load actual data on first click\n          crmHoverMenu(menuData, $crmMenu);\n          menuLoaded = true;\n        }\n\n        $crmMenu.toggleClass(\"show\");\n        if ($crmMenu.hasClass(\"show\") && $(window).width() <= 780) {\n          $(\"body\").addClass(\"no-scroll\");\n        } else {\n          $(\"body\").removeClass(\"no-scroll\");\n        }\n      });\n\n      if ($(window).width() >= 781) {\n        $myAccount.hover(\n          function () {\n            if (!menuLoaded) {\n              // Load actual data on first hover\n              crmHoverMenu(menuData, $crmMenu);\n              menuLoaded = true;\n            }\n            $crmMenu.addClass(\"show\");\n          },\n          function () {\n            $crmMenu.removeClass(\"show\");\n          },\n        );\n      }\n\n      // Prevent touch event interference on the menu itself\n      $(document).on(\"touchstart touchmove\", \".crm-menu\", function (event) {\n        event.stopPropagation();\n      });\n\n      // Add click handler to close menu when clicking outside\n      $(document).on(\"click touchstart\", function (event) {\n        if (\n          !$(event.target).closest(\".crm-menu\").length &&\n          !$(event.target).closest(\".flm_myAccount\").length\n        ) {\n          event.stopPropagation();\n          $(\".crm-menu\").removeClass(\"show\");\n          $(\"body\").removeClass(\"no-scroll\");\n        }\n      });\n    }\n\n    // Create skeleton menu structure\n    function createSkeletonMenu(menuData) {\n      const $crmMenu = $('<div class=\"crm-menu\"></div>');\n\n      // Skeleton profile section\n      const $profileSkeleton = $(`\n    <div class=\"profile\"> \n      <div class=\"profile-container\">\n        <div class=\"client-details\">\n          <div class=\"client-image-skeleton skeleton\"></div>\n          <div class=\"client-info\">\n            <div class=\"name-skeleton skeleton\"></div>\n            <div class=\"crmId-skeleton skeleton\"></div>\n            <div class=\"email-skeleton skeleton\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  `);\n\n      // Skeleton points section\n      const $pointsSkeleton = $(`\n    <div class=\"points\">\n      <div class=\"client-points\">\n        <div class=\"description-skeleton skeleton\"></div>\n        <div class=\"value-skeleton skeleton\"></div>\n      </div>\n      <div class=\"client-points\">\n        <div class=\"description-skeleton skeleton\"></div>\n        <div class=\"value-skeleton skeleton\"></div>\n      </div>\n    </div>\n  `);\n\n      // Real menu items from headerMenuConfig.json (not skeleton)\n      const $crmMenuContent = $('<div class=\"crm-menu-content\"></div>');\n\n      // Hardcoded My Account link at the top\n      const myAccountCaption =\n        (window.captions && window.captions.webapp_MyAccount) || \"My Account\";\n      const $myAccountItem = $(\n        `<a class=\"crm-menu-item\" href=\"/my-account\">${myAccountCaption}</a>`,\n      );\n      $myAccountItem.prepend(\n        $('<img src=\"/cus/beta/images/User.svg\" alt=\"My Account\" class=\"icon\">'),\n      );\n      $crmMenuContent.append($myAccountItem);\n\n      menuData.forEach((item) => {\n        const captionTitle = getCaption(item.link, item.title);\n        const $menuItem = $(\n          `<a class=\"crm-menu-item\" href=\"${item.link}\">${captionTitle}</a>`,\n        );\n        const $icon = getIcon(item.link);\n        $menuItem.prepend($icon);\n        $crmMenuContent.append($menuItem);\n      });\n\n      // Real logout (not skeleton)\n      const $logout = $(\n        `<a href=\"/CrmLogin.aspx?CRMAction=logout\" class=\"crm-menu-item logout\"><img src=\"/cus/beta/images/LogOut.svg\" alt=\"log out\" class=\"icon\">${getCaption(\"/CrmLogin.aspx?CRMAction=logout\", \"Log Out\")}</a>`,\n      );\n\n      $crmMenu.append($profileSkeleton);\n      $crmMenu.append($pointsSkeleton);\n      $crmMenu.append($crmMenuContent);\n      $crmMenu.append($logout);\n\n      // Add getIcon function to this scope\n      function getIcon(itemLink) {\n        const basePath = \"/cus/beta/images/\";\n        const icons = {\n          ActiveTickets: \"Ticket.svg\",\n          friends: \"Meet and Greet.svg\",\n          PersonalDetails: \"User.svg\",\n          ActiveSubs: \"Seat.svg\",\n          ActiveTicketSchemeEnrollments: \"Venue.svg\",\n          ActiveMemberships: \"Pass.svg\",\n          CreditCards: \"Creditcard.svg\",\n          History: \"History.svg\",\n          logout: \"LogOut.svg\",\n          QualityPoints: \"quality.svg\",\n          LoyaltyPoints: \"loyalty.svg\",\n          Reservations: \"reservations.svg\",\n          BallotApplication: \"Ballots.svg\",\n        };\n\n        const matchedKey = Object.keys(icons).find((key) =>\n          itemLink.includes(key),\n        );\n        const iconFile = matchedKey ? icons[matchedKey] : \"Ticket.svg\";\n\n        return $(\n          `<img src=\"${basePath}${iconFile}\" alt=\"${\n            matchedKey || \"Ticket\"\n          }\" class=\"icon\">`,\n        );\n      }\n\n      // Add getCaption function to get localized captions based on link\n      function getCaption(itemLink, fallbackTitle) {\n        const captionMap = {\n          PersonalDetails: \"webapp_PersonalDetails\",\n          \"personal-info\": \"webapp_PersonalDetails\", // for /my-account/personal-info\n          Reservations: \"webapp_Reservations\",\n          events: \"webapp_Tickets\", // for /my-account/events\n          \"friends-and-family\": \"webapp_FriendsFamily\", // for /my-account/friends-and-family\n          ActiveSubs: \"webapp_SeasonTickets\",\n          ActiveTicketSchemeEnrollments: \"webapp_TicketScheme\",\n          ActiveMemberships: \"webapp_Membership\",\n          memberships: \"webapp_Membership\", // for /my-account/memberships\n          CreditCards: \"webapp_CreditCards\",\n          payments: \"webapp_CreditCards\", // for /my-account/payments\n          BallotApplications: \"webapp_Ballots\",\n          History: \"webapp_History\",\n          QualityPoints: \"webapp_QualityPoints\",\n          LoyaltyPoints: \"webapp_LoyaltyPoints\",\n          logout: \"webapp_LogOut\",\n        };\n\n        const matchedKey = Object.keys(captionMap).find((key) =>\n          itemLink.includes(key),\n        );\n\n        if (\n          matchedKey &&\n          window.captions &&\n          window.captions[captionMap[matchedKey]]\n        ) {\n          return window.captions[captionMap[matchedKey]];\n        }\n\n        return fallbackTitle; // Return original title if no caption found\n      }\n\n      return $crmMenu;\n    }\n\n    function getCountryCodeForFlag(cultureId) {\n      // \"nl-NL\" -> \"nl\", \"en-GB\" -> \"gb\", \"sr-Cyrl-BA\" -> \"ba\"\n      var parts = cultureId.split(\"-\");\n      return parts[parts.length - 1].toLowerCase();\n    }\n\n    function getShortCode(cultureId) {\n      // \"nl-NL\" -> \"NL\", \"en-GB\" -> \"GB\", \"sr-Cyrl-BA\" -> \"BA\"\n      var parts = cultureId.split(\"-\");\n      return parts[parts.length - 1].toUpperCase();\n    }\n\n    function createCultureSelector($inner) {\n      getSiteConfig()\n        .then(function (config) {\n          var cultures = config && config.acceptedCultures;\n          if (!cultures || cultures.length <= 1) return;\n\n          var currentCultureId = ($eSRO && $eSRO.culture) ? $eSRO.culture : \"\";\n          var currentCulture =\n            cultures.find(function (c) { return c.cultureId === currentCultureId; }) ||\n            cultures[0];\n\n          var flagCode = getCountryCodeForFlag(currentCulture.cultureId);\n          var shortCode = getShortCode(currentCulture.cultureId);\n\n          var $container = $(\n            '<div class=\"cultureSelectorContainer\" id=\"cultureSelectorContainer\"></div>'\n          );\n\n          var $button = $(\n            '<button class=\"cultureSelectorBtn\" id=\"culture-selector-button\"' +\n            ' type=\"button\" aria-haspopup=\"listbox\" aria-label=\"Select language and country\">' +\n            '<span class=\"fi fi-' + flagCode + '\" aria-hidden=\"true\"></span>' +\n            \"<span>\" + shortCode + \"</span>\" +\n            \"</button>\"\n          );\n\n          var $dropdown = $(\n            '<ul class=\"cultureSelectorDropdown\" role=\"listbox\" tabindex=\"-1\"' +\n            ' aria-labelledby=\"culture-selector-button\"></ul>'\n          );\n\n          cultures.forEach(function (culture) {\n            var isSelected = culture.cultureId === currentCultureId;\n            var cFlagCode = getCountryCodeForFlag(culture.cultureId);\n            var cShortCode = getShortCode(culture.cultureId);\n            var $item = $(\n              '<li role=\"menuitem\" tabindex=\"' + (isSelected ? \"0\" : \"-1\") + '\"' +\n              (isSelected ? ' class=\"selected\"' : \"\") +\n              ' aria-label=\"' + culture.name + \" (\" + cShortCode + ')\"' +\n              ' data-culture-id=\"' + culture.cultureId + '\">' +\n              '<span class=\"cultureFlagName\">' +\n              '<span class=\"fi fi-' + cFlagCode + '\" aria-hidden=\"true\"></span>' +\n              \"<span>\" + culture.shortName + \"</span>\" +\n              \"</span>\" +\n              \"<span>\" + cShortCode + \"</span>\" +\n              \"</li>\"\n            );\n            $dropdown.append($item);\n          });\n\n          $container.append($button).append($dropdown);\n          $inner.append($container);\n\n          $button.on(\"click\", function (e) {\n            e.stopPropagation();\n            $container.toggleClass(\"open\");\n          });\n\n          $(document).on(\"click.cultureSelector\", function () {\n            $container.removeClass(\"open\");\n          });\n\n          $dropdown.on(\"click\", \"li\", function (e) {\n            e.stopPropagation();\n            var cultureId = $(this).data(\"culture-id\");\n            if (cultureId && cultureId !== currentCultureId) {\n              window.location.href =\n                window.location.pathname + \"?culture=\" + cultureId;\n            }\n          });\n        })\n        .catch(function (err) {\n          console.log(\"Culture selector: failed to load site config\", err);\n        });\n    }\n\n    // Modified crmHoverMenu to accept existing menu element\n    function crmHoverMenu(menuData, $existingMenu) {\n      require([\"web-api\"], function (api) {\n        Promise.all([\n          api.call(\"v1.0/profiles/:profileId/summary\", {\n            headers: { \"Accept-Language\": getAcceptLanguageHeader() }\n          }),\n          getSiteConfig(),\n        ])\n          .then(function (results) {\n            var summaryData = results[0].data;\n            var config = results[1];\n\n            if (\n              (summaryData &&\n                summaryData.message &&\n                summaryData.message.indexOf(\"No auth for the web API\") !==\n                  -1) ||\n              (config &&\n                config.message &&\n                config.message.indexOf(\"No auth for the web API\") !== -1)\n            ) {\n              // Fallback: use local client data\n              replaceCrmMenuContent(\n                $existingMenu,\n                {\n                  fullName: $eSRO.client.name,\n                  email: $eSRO.client.email,\n                },\n                menuData,\n              );\n            } else {\n              // Otherwise, merge the API responses and call buildCrmMenu\n              replaceCrmMenuContent(\n                $existingMenu,\n                {\n                  fullName: summaryData.fullName,\n                  loyaltyPointsBalance: summaryData.loyaltyPointsBalance,\n                  qualityPointsBalance: summaryData.qualityPointsBalance,\n                  email: summaryData.email,\n                  crmId: summaryData.generalInfo.supporterId,\n                  imageUrl: summaryData.imageUrl,\n                },\n                menuData,\n                config,\n              );\n            }\n          })\n          .catch(function (err) {\n            console.log(\"API error\", err);\n            replaceCrmMenuContent(\n              $existingMenu,\n              {\n                fullName: $eSRO.client.name,\n                email: $eSRO.client.email,\n              },\n              menuData,\n            );\n          });\n      });\n    }\n\n    // Replace skeleton content with actual data\n    function replaceCrmMenuContent(\n      $crmMenu,\n      profileSummary,\n      menuData,\n      siteConfig,\n    ) {\n      // Debug: Log before replacement\n      console.log(\"Before replacement - menu height:\", $crmMenu.outerHeight());\n      console.log(\n        \"Profile section height:\",\n        $crmMenu.find(\".profile\").outerHeight(),\n      );\n      console.log(\n        \"Points section height:\",\n        $crmMenu.find(\".points\").outerHeight(),\n      );\n\n      // Build points HTML\n      let pointsHtml = '<div class=\"points\">';\n      const hasLP =\n        siteConfig &&\n        siteConfig.displayLoyaltyPoints &&\n        profileSummary.loyaltyPointsBalance != null &&\n        !isNaN(profileSummary.loyaltyPointsBalance);\n      const hasQP =\n        siteConfig &&\n        siteConfig.displayQualityPoints &&\n        profileSummary.qualityPointsBalance != null &&\n        !isNaN(profileSummary.qualityPointsBalance);\n\n      if (hasLP) {\n        pointsHtml += `<div class=\"client-points\">\n      <div class=\"description\">${\n        window.captions.webapp_LoyaltyPoints\n          ? window.captions.webapp_LoyaltyPoints\n          : \"Loyalty Points\"\n      }</div>\n      <div class=\"value\">${profileSummary.loyaltyPointsBalance}</div>\n    </div>`;\n      }\n\n      if (hasQP) {\n        pointsHtml += `<div class=\"client-points\">\n      <div class=\"description\">${\n        window.captions.webapp_QualityPoints\n          ? window.captions.webapp_QualityPoints\n          : \"Quality Points\"\n      }</div>\n      <div class=\"value\">${profileSummary.qualityPointsBalance}</div>\n    </div>`;\n      }\n      pointsHtml += \"</div>\";\n\n      // Build profile HTML\n      const $profileMenu = $(`<div class=\"profile\"> \n    <div class=\"profile-container\">\n      <div class=\"client-details\">\n      ${\n        profileSummary.imageUrl && profileSummary.imageUrl !== \"null\"\n          ? `<div class=\"client-image\"><img src=\"${profileSummary.imageUrl}\"></div>`\n          : \"\"\n      }\n        <div class=\"client-info\">\n          <div class=\"name\">${profileSummary.fullName}</div>\n          <div class=\"crmId\">${\n            profileSummary.crmId != null && profileSummary.crmId\n              ? profileSummary.crmId\n              : \"\"\n          }</div>\n          <div class=\"email\">${profileSummary.email}</div>\n        </div>\n      </div>\n    </div>\n  </div>`);\n\n      // Replace only the skeleton sections, keep the menu items\n      $crmMenu.find(\".profile\").replaceWith($profileMenu);\n\n      if (hasQP || hasLP) {\n        $crmMenu.find(\".points\").replaceWith($(pointsHtml));\n      } else {\n        // Hide points section with transition instead of removing\n        $crmMenu.find(\".points\").css({\n          height: \"0\",\n          padding: \"0\",\n          border: \"none\",\n          overflow: \"hidden\",\n        });\n      }\n\n      // Debug: Log after replacement\n      console.log(\"After replacement - menu height:\", $crmMenu.outerHeight());\n      console.log(\n        \"New profile section height:\",\n        $crmMenu.find(\".profile\").outerHeight(),\n      );\n      console.log(\n        \"New points section height:\",\n        $crmMenu.find(\".points\").outerHeight(),\n      );\n\n      // Add click handler for anchor links\n      $crmMenu.on(\"click\", \"a[href^='#']\", function () {\n        $(\".crm-menu\").removeClass(\"show\");\n        $(\"body\").removeClass(\"no-scroll\");\n      });\n    }\n    function createNewAccountIcon() {\n      // Check if initials are available in $eSRO.client\n      if ($eSRO.client.initials) {\n        $(\"#navMenu_Float_myAccount_item span\").text($eSRO.client.initials);\n        $(\"body\").addClass(\"crm-initials-loaded\");\n      } else {\n        // Fallback to name parsing if initials not available\n        const clientName = $eSRO.client.name;\n        let clientNameParts = clientName.match(/\\b[A-Za-z]+\\b/g);\n\n        if (clientNameParts && clientNameParts.length > 0) {\n          const titles = [\"mr\", \"mrs\", \"ms\", \"dr\", \"prof\"];\n          while (\n            clientNameParts.length > 1 &&\n            titles.includes(clientNameParts[0].toLowerCase())\n          ) {\n            clientNameParts.shift();\n          }\n\n          if (clientName.includes(\",\")) {\n            clientNameParts = clientNameParts.reverse();\n          }\n\n          const firstInitial = clientNameParts[0].charAt(0).toUpperCase();\n          const lastInitial = clientNameParts[clientNameParts.length - 1]\n            .charAt(0)\n            .toUpperCase();\n\n          $(\"#navMenu_Float_myAccount_item span\").text(\n            firstInitial + lastInitial,\n          );\n          $(\"body\").addClass(\"crm-initials-loaded\");\n        } else {\n          $(\"#navMenu_Float_myAccount_item span\").text(\"??\");\n        }\n      }\n    }\n\n    function createDesktopMenu(data) {\n      let $menu = $(\n        '<ul class=\"navbar-nav\"><div class=\"nav-header\"><div class=\"logo\"></div><div class=\"nav-close\"><i class=\"fa fa-close\"></i></div></div></ul>',\n      );\n      data.forEach((item) => {\n        const menuItem = $(\"<li></li>\");\n        const title = getTitleOrCaption(item);\n        const link = $(`<a href=\"${item.link || \"#\"}\">${title}</a>`);\n\n        menuItem.append(link);\n\n        // Check for subItems\n        if (item.children) {\n          link.addClass(\"menu-link\"); // Add a class for dropdown indicator\n          link.append(\n            `<span class=\"drop-icon\"><i class=\"fas fa-chevron-down\"></i><i class=\"fas fa-chevron-right\"></i></span>`,\n          );\n          const subMenu = $(\n            '<div class=\"sub-menu\" style=\"display: none;\"><div class=\"nav-header sub-header\"><div class=\"back\"><i class=\"fas fa-chevron-left\"></i></div><div class=\"nav-close\"><i class=\"fa fa-close\"></i></div></div></div>',\n          ); // Create sub-menu wrapper\n\n          // Process subItems\n          item.children.forEach((subItem) => {\n            const subMenuItem = $('<div class=\"sub-menu-item\"></div>');\n\n            if (subItem.children) {\n              if (subItem.title) {\n                const subTitle = getTitleOrCaption(subItem);\n                subMenuItem.append(\n                  `<h4 class=\"submenu-header\">${subTitle}</h4>`,\n                ); // Add the header with a class\n              }\n\n              const subSubMenu = $(\"<ul></ul>\"); // Create the nested <ul>\n\n              subItem.children.forEach((subSubItem) => {\n                const subSubTitle = getTitleOrCaption(subSubItem);\n                subSubMenu.append(\n                  `<li><a href=\"${subSubItem.link}\">${subSubTitle}</a></li>`,\n                ); // Add sub-items\n              });\n\n              subMenuItem.append(subSubMenu); // Add the nested <ul> to the item\n            } else {\n              subMenu.addClass(\"vertical\");\n              const subTitle = getTitleOrCaption(subItem);\n              subMenuItem.append(\n                `<a href=\"${subItem.link}\" class=\"submenu-link\">${subTitle}</a>`,\n              ); // Add link with a class\n            }\n\n            subMenu.append(subMenuItem); // Add the processed sub-menu item\n          });\n\n          menuItem.append(subMenu); // Add the full sub-menu to the <li>\n        } else {\n          link.addClass(\"menu-link-no-children\"); // Add a class for items without children\n        }\n\n        $menu.append(menuItem); // Add the processed <li> to the <ul>\n      });\n      return $menu;\n    }\n\n    function buildMenuMobile(items) {\n      let $navPanel = $(\n        '<div class=\"nav-panel\"><div class=\"nav-main\"><div class=\"nav-content\"></div></div></div>',\n      );\n\n      items.forEach((item) => {\n        const $menuItem = $(\"<div class='nav-item'></div>\");\n        const title = getTitleOrCaption(item);\n        const $link = $(`<div class=\"nav-link\">${title}</div>`);\n\n        $menuItem.append($link);\n\n        // Check for children\n        if (item.children) {\n          $link.addClass(\"menu-link\");\n          $link.append(\n            `<span class=\"drop-icon\"><i class=\"fas fa-chevron-right\"></i></span>`,\n          );\n\n          let $subMenuPanel = $(\n            '<div class=\"nav-subMenu\"><div class=\"nav-content\"></div></div>',\n          );\n          let $subContent = $subMenuPanel.find(\".nav-content\");\n\n          item.children.forEach((subItem) => {\n            const $subMenuItem = $('<div class=\"nav-item\"></div>');\n            const subTitle = getTitleOrCaption(subItem);\n            const $subLink = $(`<div class=\"nav-link\">${subTitle}</div>`);\n            $subMenuItem.append($subLink);\n\n            if (subItem.children) {\n              $subLink.append(\n                `<span class=\"drop-icon\"><i class=\"fas fa-chevron-right\"></i></span>`,\n              );\n              let $subSubMenuPanel = $(\n                '<div class=\"nav-subSubMenu\"><div class=\"nav-content\"></div></div>',\n              );\n              let $subSubMenuContent = $subSubMenuPanel.find(\".nav-content\");\n\n              subItem.children.forEach((subSubItem) => {\n                const $subSubMenuItem = $('<div class=\"nav-item\"></div>');\n                const subSubTitle = getTitleOrCaption(subSubItem);\n                const navLink = $(`<div class=\"nav-link\">${subSubTitle}</div>`);\n                navLink.click(function () {\n                  window.location.href = subSubItem.link;\n                });\n                $subSubMenuItem.append(navLink);\n\n                $subSubMenuContent.append($subSubMenuItem);\n              });\n\n              $subMenuItem.click(function () {\n                $navPanel.find(\".nav-subSubMenu\").detach();\n                $navPanel.find(\".nav-subMenu\").before($subSubMenuPanel);\n                $(\".back\").show();\n\n                $(\".nav-subSubMenu\")[0].offsetHeight;\n\n                $navPanel.children().removeClass(\"slide-first\");\n                $navPanel.children().addClass(\"slide-second\");\n\n                $(\".nav-close\").click(function () {\n                  $navPanel.removeClass(\"show\");\n                  $(\".navbar-wrapper\").removeClass(\"show\");\n                  $(\".nav-header\").removeClass(\"show\");\n                  $navPanel.children().removeClass(\"slide-first\");\n                  $navPanel.children().removeClass(\"slide-second\");\n                  $subMenuPanel.detach();\n                  $subSubMenuPanel.detach();\n                });\n              });\n\n              $subContent.append($subMenuItem);\n            } else {\n              $subLink.click(function () {\n                window.location.href = subItem.link;\n              });\n            }\n\n            $subContent.append($subMenuItem);\n          });\n\n          $link.click(function () {\n            $navPanel.find(\".nav-subMenu\").detach();\n            $navPanel.find(\".nav-main\").before($subMenuPanel);\n            $(\".back\").show();\n            $(\".nav-subMenu\")[0].offsetHeight;\n\n            $navPanel.children().addClass(\"slide-first\");\n\n            $(\".nav-close\").click(function () {\n              $navPanel.removeClass(\"show\");\n              $(\".navbar-wrapper\").removeClass(\"show\");\n              $(\".nav-header\").removeClass(\"show\");\n              $navPanel.children().removeClass(\"slide-first\");\n              $subMenuPanel.detach();\n            });\n          });\n\n          //test\n        } else {\n          $link.click(function () {\n            window.location.href = item.link;\n          });\n        }\n\n        $navPanel.find(\".nav-content\").append($menuItem);\n      });\n\n      return $navPanel;\n    }\n\n    function replaceUIMenu(desktopMenu, mobileMenu) {\n      const oldMenu = $(\"#PH_Menu\");\n      const oldMobileMenu = $(\"#PH_MenuButton\");\n      const largeLogo = $(\"#PH_LargeLogo\");\n      const menuContainer = $(\n        '<div id=\"menuContainer\"><nav class=\"navbar\"><div class=\"navbar-collapse\"></div></div></div>',\n      );\n      const mobileMenuContainer = $(\n        '<button type=\"button\" class=\"navbar-toggler\"><i class=\"fas fa-bars\"></i></button>',\n      );\n      const mobileMenuLocation = $(params.mobileMenuLocation);\n      const desktopMenuLocation = $(params.desktopMenuLocation);\n\n      oldMenu.hide();\n      desktopMenuLocation.after(menuContainer);\n      menuContainer.find(\".navbar-collapse\").append(desktopMenu);\n      var $wrapContainer = $('<div class=\"navbar-wrapper\"></div>');\n      menuContainer.find(\".navbar-collapse\").after($wrapContainer);\n      $wrapContainer.append(mobileMenu);\n      const $navHeader = $(\n        '<div class=\"nav-header\"><div class=\"back\"><i class=\"fas fa-chevron-left\"></i></div><div class=\"nav-close\"><i class=\"fa fa-close\"></i></div></div>',\n      );\n      $navHeader.find(\".back\").hide();\n      menuContainer.find(\".navbar-collapse\").after($navHeader);\n      oldMobileMenu.hide();\n\n      if (mobileMenuLocation.length > 0) {\n        mobileMenuLocation.after(mobileMenuContainer);\n      } else if (largeLogo.length > 0) {\n        largeLogo.after(mobileMenuContainer);\n      } else {\n        oldMobileMenu.after(mobileMenuContainer);\n      }\n\n      if (params.htmlInjection.html !== \"\") injectHtml(menuContainer);\n    }\n\n    function goBack() {\n      if ($(\".nav-panel > div\").hasClass(\"slide-second\")) {\n        $(\".nav-panel > div\").removeClass(\"slide-second\");\n        $(\".nav-subSubMenu\").detach();\n        $(\".nav-panel > div\").addClass(\"slide-first\");\n      } else if ($(\".nav-panel > div\").hasClass(\"slide-first\")) {\n        $(\".nav-panel > div\").removeClass(\"slide-first\");\n        $(\".nav-subMenu\").detach();\n      }\n    }\n\n    function buildLinks() {\n      $(\".navbar-toggler\").click(function () {\n        $(\".nav-panel, .nav-header, .navbar-wrapper\").toggleClass(\"show\");\n      });\n\n      $(\".nav-close\").click(function () {\n        console.log(\">\");\n        $(\".nav-panel, .nav-header, .navbar-wrapper\").toggleClass(\"show\");\n        $(\".sub-menu\").removeClass(\"open\");\n      });\n\n      $(\".back\").click(function () {\n        goBack();\n      });\n\n      let menuLinks = $(\".nav-panel .menu-link\");\n      buildMobileLinks(menuLinks);\n    }\n\n    function onResize(mobileBreakpoint) {\n      console.log(\n        `Window Width: ${$(\n          window,\n        ).innerWidth()}, breakpoint: ${mobileBreakpoint}`,\n      );\n      if ($(window).innerWidth() < mobileBreakpoint) {\n        $(\".navbar\").addClass(\"mobile\");\n        $(\".navbar-toggler\").show();\n      } else {\n        $(\".navbar\").removeClass(\"mobile\");\n        $(\".navbar-toggler\").hide();\n        $(\".nav-panel\").removeClass(\"open\");\n        $('.nav-panel > div:not(\".nav-main\")').detach();\n        $(\".nav-main\").removeClass(\"slide-first slide-second\");\n      }\n    }\n\n    function buildMobileLinks(menuLinks) {\n      console.log(menuLinks);\n      menuLinks.each(function (item) {\n        $(this).click(function () {\n          $(this).next().slideToggle();\n          $(this).next().toggleClass(\"open\");\n        });\n      });\n    }\n\n    function injectHtml(menuContainer) {\n      const $htmlInjection = $(params.htmlInjection.html);\n      if (params.htmlInjection.location === \"\")\n        $(menuContainer).append($htmlInjection);\n      else $(params.htmlInjection.location).append($htmlInjection);\n    }\n  });\n})();\n"
