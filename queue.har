          "content": {
            "size": 1626,
            "mimeType": "application/javascript",
            "text": "// TEST\r\n\r\nrequire.config({\r\n\tpaths: {\r\n\t\tinitialiseSettings: \"/cus/release/js/initialiseSettings\",\r\n\t\tsettingsUtil: \"/cus/release/js/settingsUtil\",\r\n\t\tcommonFunctions: \"/cus/release/js/commonFunctions\",\r\n\t\tdefaultSettings: \"/cus/release/js/defaultSettings\",\r\n\t\tclientSettings: \"/usercontent/js/clientSettings\",\r\n\t\tcommon: \"/cus/release/js/common\",\r\n\t},\r\n});\r\n\r\ndefine(\"initialiseSettings\", [\"settingsUtil\", \"commonFunctions\"], function (settingsUtil, commonFunctions) {\r\n\tconsole.log(\"initialiseSettings loaded\");\r\n\tfunction initialise() {\r\n\t\tvar mergedSettings = settingsUtil.mergeSettings();\r\n\t\tconsole.log(mergedSettings);\r\n\r\n\t\t// Now call the addBodyClasses function directly with the addBodyClasses settings object\r\n\t\tif (mergedSettings.addBodyClasses && mergedSettings.addBodyClasses.enabled) {\r\n\t\t\tcommonFunctions.addBodyClasses(mergedSettings.addBodyClasses);\r\n\t\t}\r\n\r\n\t\tObject.entries(mergedSettings).forEach(([key, value]) => {\r\n\t\t\t// Check if the setting is an object and has an \"enabled\" property\r\n\t\t\tif (typeof value === \"object\" && \"enabled\" in value) {\r\n\t\t\t\t// If the setting is enabled, and there is a matching function, call it\r\n\t\t\t\tif (value.enabled && typeof commonFunctions[key] === \"function\") {\r\n\t\t\t\t\tcommonFunctions[key](value);\r\n\t\t\t\t}\r\n\t\t\t} else if (key !== \"addBodyClasses\" && typeof commonFunctions[key] === \"function\") {\r\n\t\t\t\t// If the setting does not have an \"enabled\" property but matches a function, call it\r\n\t\t\t\t// This handles cases where settings might not be feature toggles but direct configurations\r\n\t\t\t\tcommonFunctions[key](value);\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\r\n\treturn {\r\n\t\tinitialise,\r\n\t};\r\n});\r\n"
          },
          "redirectURL": "",
          "headersSize": -1,
          "bodySize": -1,
