          "content": {
            "size": 47694,
            "mimeType": "application/javascript",
            "text": "define(\"commonFunctions\", [], function () {\r\n  function addBodyClasses(classesObject) {\r\n    // Check if adding classes is enabled\r\n    if (!classesObject.enabled) return;\r\n\r\n    // Iterate over the classesObject, excluding the 'enabled' property\r\n    Object.keys(classesObject).forEach(function (className) {\r\n      if (className !== \"enabled\" && classesObject[className]) {\r\n        // Add the class to the body tag if the property is set to true\r\n        document.body.classList.add(className);\r\n      }\r\n    });\r\n  }\r\n  /* Hide hospitality packages if unavailable */\r\n  function hideUnavailablePackages() {\r\n    if ($eSRO.currentScreen === \"hospitalityevent.aspx\") {\r\n      $(\".dataItem\").each(function () {\r\n        if (\r\n          $(this)\r\n            .children(\".itemsButtonsContainer\")\r\n            .children(\".button\")\r\n            .is(\".disabled\")\r\n        ) {\r\n          $(this).hide();\r\n        }\r\n      });\r\n    }\r\n  }\r\n\r\n  /* Add a hospitality prompt on the area selection */\r\n  function hospitalityUpsell(params) {\r\n    if ($eSRO.currentScreen === \"event4.aspx\") {\r\n      var legendContainer =\r\n        '<div class=\"legend-container\" id=\"stadium-key\"></div>';\r\n      var upsell = $(\r\n        '<div class=\"hospitality-upsell\">' + params.content + \"</div>\"\r\n      );\r\n      if ($(\"#stadium-key\").length <= 0) {\r\n        $(legendContainer).clone().appendTo(\".vfaParent\");\r\n      }\r\n      $(upsell).clone().prependTo(\"#stadium-key\");\r\n    }\r\n  }\r\n\r\n  /* Add a message at the top of the ticket selection */\r\n  function nonSeatedMessage(params) {\r\n    if (\r\n      $eSRO.currentScreen === \"event4.aspx\" &&\r\n      window.location.href.indexOf(params.eventName) > -1\r\n    ) {\r\n      var messageContainer =\r\n        '<div class=\"content-wrapper\">' + params.content + \"</div>\";\r\n      $(messageContainer).clone().prependTo(\"#content\");\r\n    }\r\n    if ($eSRO.currentScreen === \"event4.aspx\" && params.additionalMessages) {\r\n      params.additionalMessages.forEach((event) => {\r\n        if (event.enabled && window.location.href.indexOf(event.eventName) > -1)\r\n          var messageContainer =\r\n            '<div class=\"content-wrapper\">' + event.content + \"</div>\";\r\n        $(messageContainer).clone().prependTo(\"#content\");\r\n      });\r\n    }\r\n  }\r\n\r\n  /* Seperate password reset page */\r\n  function passwordReset() {\r\n    $(\"body\").on(\"dialogopen\", \".loginOrRegisterDlg\", function () {\r\n      $(\".loginOrRegisterWizard a#btnForgot\")\r\n        .after(\r\n          $(\r\n            '<a class=\"btnForgotPassword\" href=\"/crmlogin.aspx\">Forgot Password</a>'\r\n          )\r\n        )\r\n        .hide();\r\n    });\r\n    $(\".loginOrRegisterWizard #btnForgot\").attr(\"href\", \"/crmlogin.aspx\");\r\n    $(\".loginOrRegisterWizard #btnForgot\").on(\"click\", function (e) {\r\n      window.location = \"/crmlogin.aspx\";\r\n    });\r\n    if ($eSRO.currentScreen === \"linkcustomer.aspx\") {\r\n      $(\"#loginOrSignup a#btnForgot\")\r\n        .after(\r\n          $(\r\n            '<a class=\"btnForgotPassword\" href=\"/crmlogin.aspx\">Forgot Password</a>'\r\n          )\r\n        )\r\n        .hide();\r\n    }\r\n    $(\"body\").addClass(\"password-reset\");\r\n  }\r\n\r\n  /* Next match landing page panel */\r\n  function nextMatch() {\r\n    if ($eSRO.currentScreen === \"recommendedevents.aspx\") {\r\n      if ($(\".no_events_message\").length) {\r\n        $(\"body\").addClass(\"no_events\");\r\n      } else if ($(\"#next-match\").length > 0) {\r\n        $(\"#ctl00_body_EventsListControl\").clone().prependTo(\"#next-match\");\r\n        $(\"#next-match .dataItem\").each(function () {\r\n          $(this)\r\n            .children(\".itemsDataContainer\")\r\n            .children(\".description\")\r\n            .clone()\r\n            .appendTo($(this).children(\".itemsDateRange\"));\r\n        });\r\n      }\r\n    }\r\n  }\r\n\r\n  /* Display stadium key */\r\n  function displayStadiumKey(params) {\r\n    if ($eSRO.currentScreen === \"event4.aspx\") {\r\n      $(\"body\").addClass(\"display-stadium-key\");\r\n      var legendContainer =\r\n        '<div class=\"legend-container\" id=\"stadium-key\"></div>';\r\n      if ($(\"#stadium-key\").length <= 0) {\r\n        $(legendContainer).clone().appendTo(\".vfaParent\");\r\n      }\r\n      $(params.content).clone().appendTo(\"#stadium-key\");\r\n    }\r\n  }\r\n\r\n  /* Display seat key */\r\n  function displaySeatKey(params) {\r\n    if ($eSRO.currentScreen === \"event4.aspx\") {\r\n      $(\"body\").addClass(\"display-seat-key\");\r\n      var legendContainer =\r\n        '<div class=\"legend-container\" id=\"seat-key\"></div>';\r\n      if ($(\"#seat-key\").length <= 0) {\r\n        $(legendContainer).clone().appendTo(\".seatingPlanContainer\");\r\n      }\r\n      $(params.content).clone().appendTo(\"#seat-key\");\r\n    }\r\n  }\r\n\r\n  /* Replace Seat Key */\r\n  function replaceSeatMessageAndKey(params) {\r\n    if ($eSRO.currentScreen === \"crmdetails.aspx\") {\r\n      var keyCounter = setInterval(function () {\r\n        if ($(\".replaceSubsTickets\").length > 0) {\r\n          var messageContainer = '<div class=\"message-container\"></div>';\r\n          if ($(\".message-container\").length <= 0) {\r\n            $(messageContainer).clone().prependTo(\".infoSection\");\r\n            $(params.content).clone().appendTo(\".message-container\");\r\n          }\r\n          displaySeatKey(params.key);\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  /* Display hospitality package pricing */\r\n  function displayHospitalityPricing(params) {\r\n    if ($eSRO.currentScreen === \"hospitalityevent.aspx\") {\r\n      var showID = $(\".showID\").text();\r\n      var completeCheck = 0;\r\n      var FEED_URL =\r\n        \"/feed/events?showid=\" + showID + \"&withpricing=true&hospitality\";\r\n      $.get(FEED_URL, function (data) {\r\n        $(\".dataItem\").each(function () {\r\n          var container = $(this).attr(\"data-id\");\r\n          completeCheck = 0;\r\n          $(data)\r\n            .find(\"Entry\")\r\n            .each(function () {\r\n              var el = $(this);\r\n              if (\r\n                el.attr(\"PriceLevelGuid\") == container &&\r\n                el.attr(\"TotalPrice\") != \"N/A\" &&\r\n                completeCheck == 0\r\n              ) {\r\n                var dataID = el.attr(\"PriceLevelGuid\");\r\n                var totalPrice = el.attr(\"TotalPrice\");\r\n                displayPrice(totalPrice, dataID);\r\n                completeCheck = 1;\r\n              }\r\n            });\r\n        });\r\n      });\r\n\r\n      function displayPrice(totalPrice, dataID) {\r\n        var price = $(\r\n          '<span class=\"name\">' +\r\n            params.content +\r\n            '</span><span class=\"price\">£' +\r\n            totalPrice +\r\n            \"</span>\"\r\n        );\r\n        $(\".dataItem[data-id='\" + dataID + \"'] .itemsButtonsContainer\").prepend(\r\n          price\r\n        );\r\n      }\r\n    }\r\n  }\r\n\r\n  /* Hide Available Seat Qty */\r\n  function hideAvailabilitySeatQty() {\r\n    if ($eSRO.currentScreen == \"event4.aspx\") {\r\n      $(\".availSeats\").remove();\r\n    }\r\n  }\r\n\r\n  /* Promo Box */\r\n  function promoBox(params) {\r\n    if ($(\".promoBox\").length) {\r\n      $(\"body\").addClass(\"hasPromoBox\");\r\n      if ($(\".promoBox .number\").length) {\r\n        $(\"body\").addClass(\"hasPromoCode\");\r\n      } else {\r\n        var promotionTrigger = $(\r\n          '<div class=\"promotionTrigger\">' +\r\n            params.description +\r\n            \" <a>\" +\r\n            params.link +\r\n            \"</a></div>\"\r\n        );\r\n        $(\"#eventPage.hallMap #content\").prepend(promotionTrigger);\r\n      }\r\n    }\r\n    if ($(\".promoBox .number\").length) {\r\n      $(\"body\").addClass(\"hasPromoCode\");\r\n    }\r\n    $(\".promotionTrigger > a\").click(function () {\r\n      if ($(\".promoBox\").hasClass(\"show\")) {\r\n        $(\".promoBox\").removeClass(\"show\");\r\n      } else {\r\n        $(\".promoBox\").addClass(\"show\");\r\n      }\r\n    });\r\n  }\r\n\r\n  /* Gift Voucher Box */\r\n  function voucherBox(params) {\r\n    if ($(\".pmTypeGiftVoucher\").length) {\r\n      $(\"body\").addClass(\"hasVoucherBox\");\r\n      var voucherTrigger = $(\r\n        '<div class=\"voucherTrigger\">' +\r\n          params.description +\r\n          \" <a>\" +\r\n          params.link +\r\n          \"</a></div>\"\r\n      );\r\n      $(\"#PH_Payment_details\").prepend(voucherTrigger);\r\n    }\r\n    $(\".voucherTrigger > a\").click(function () {\r\n      if ($(\".pmTypeGiftVoucher\").hasClass(\"show\")) {\r\n        $(\".pmTypeGiftVoucher\").removeClass(\"show\");\r\n      } else {\r\n        $(\".pmTypeGiftVoucher\").addClass(\"show\");\r\n      }\r\n    });\r\n  }\r\n\r\n  /* Auto Expand Area Selection */\r\n  function autoExpandAreaSelection() {\r\n    var vw = Math.max(\r\n      document.documentElement.clientWidth || 0,\r\n      window.innerWidth || 0\r\n    );\r\n    if ($eSRO.currentScreen === \"event4.aspx\" && vw >= 781) {\r\n      $(\"body\").addClass(\"auto-expand-area-selection\");\r\n      var applyCheck = 0;\r\n      var functionCounter = setInterval(function () {\r\n        if (\r\n          applyCheck == 0 &&\r\n          $(\"#eventPage.hallMap .area-info-container.prompt\").length > 0\r\n        ) {\r\n          $(\"#selectedAreaInfo\").addClass(\"expanded\");\r\n          applyCheck = 1;\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  // function to allow filter search on category pages\r\n\r\n  function filtersForCategoryPage(filtersObject) {\r\n    // Create dom object for filters\r\n  }\r\n\r\n  /* Auto Check Assign Owners */\r\n  function autoCheckAssignOwners() {\r\n    if ($eSRO.currentScreen === \"order.aspx\") {\r\n      var applyCheck = 0;\r\n      var basketCounter = setInterval(function () {\r\n        if (\r\n          applyCheck == 0 &&\r\n          $(\"body\").hasClass(\"client-is-logged-in\") &&\r\n          $(\"#chkAllowOwnersAssignment\").prop(\"checked\") == false\r\n        ) {\r\n          $(\"#chkAllowOwnersAssignment\").click();\r\n          applyCheck = 1;\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  /* Change Basket Seat Location for Hospitality */\r\n\r\n  function changeBasketSeatLocationHospitality() {\r\n    if ($eSRO.currentScreen === \"order.aspx\") {\r\n      var basketHospCounter = setInterval(function () {\r\n        if ($(\".hospitalityBasketSection\").length > 0) {\r\n          $(\".hospitalityGroup\").each(function () {\r\n            $(\r\n              \".hospContentContainer .hospitalityMainItemContainer .hospMainItem .basket-section .basketEvent .basketArea\"\r\n            ).each(function () {\r\n              if ($(this).is(':contains(\"at\")')) {\r\n                $(this)\r\n                  .children(\".basketTickets\")\r\n                  .children(\".basketItem\")\r\n                  .each(function () {\r\n                    $(this)\r\n                      .children(\".basketProperty.Details\")\r\n                      .text(\"1 ticket\");\r\n                  });\r\n              }\r\n            });\r\n          });\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  function hideMembershipsList() {\r\n    if ($eSRO.currentScreen === \"membershipslist.aspx\") {\r\n      $(\"#PH_Memberships_list\").remove();\r\n      $(\"body\").removeClass(\"display-memberships-list\");\r\n    }\r\n  }\r\n\r\n  /* Hide Subscriptions List */\r\n  function hideSubscriptionList() {\r\n    if ($eSRO.currentScreen === \"subscriptionlist.aspx\") {\r\n      $(\"#PH_Subscriptions_list\").remove();\r\n      $(\"body\").removeClass(\"display-subscriptions-list\");\r\n    }\r\n  }\r\n\r\n  /* Hide Friends & Family action buttons (per-button toggles) */\r\n  function hideFriendsAndFamilyButtons(params) {\r\n    if (!params || !params.enabled) return;\r\n    if (params.hideAddFamily) {\r\n      document.body.classList.add(\"hide-friends-add-family\");\r\n    }\r\n    if (params.hideFind) {\r\n      document.body.classList.add(\"hide-friends-find\");\r\n    }\r\n    if (params.hideAddFriend) {\r\n      document.body.classList.add(\"hide-friends-add-friend\");\r\n    }\r\n  }\r\n\r\n  /* Mandatory Ticket Schemes */\r\n  function mandatoryTicketSchemes(params) {\r\n    if (\r\n      $eSRO.currentScreen === \"offers.aspx\" ||\r\n      $eSRO.currentScreen === \"order.aspx\"\r\n    ) {\r\n      $(\"body\").addClass(\"mandatoryTicketSchemes\");\r\n      var applyCheck = 0;\r\n      var functionCounter = setInterval(function () {\r\n        var i;\r\n        for (i = 0; i < params.number; i++) {\r\n          if ($(\"#fldIsSelected-_\" + i).length > 0) {\r\n            if ($(\"#fldIsSelected-_\" + i).prop(\"checked\") == false) {\r\n              $(\"#fldIsSelected-_\" + i).click();\r\n            }\r\n            $(\"#fldIsSelected-_\" + i).attr(\"disabled\", true);\r\n          }\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  /* Ballots Terms */\r\n  function ballotTerms(params) {\r\n    console.log(\"ballot\");\r\n    var applyCheck = 0;\r\n    var functionCounter = setInterval(function () {\r\n      if (\r\n        $eSRO.currentScreen === \"ballotapplication.aspx\" &&\r\n        $(\".content.paying\").length &&\r\n        applyCheck != 1\r\n      ) {\r\n        applyCheck = 1;\r\n        $(\r\n          '<p id=\"faq-accept\" class=\"small_text_a\" style=\"\"><input type=\"checkbox\" name=\"chkRead\" id=\"chkRead\"><label for=\"chkRead\">' +\r\n            params.description +\r\n            ' <a id=\"aLink\" target=\"_blank\" href=\"' +\r\n            params.link +\r\n            '\">' +\r\n            params.linkText +\r\n            \"</a></label></p>\"\r\n        ).insertBefore(\".payment-footer\");\r\n        $(\".small_button_a.proceed-button\").addClass(\"disabled-checkbox\");\r\n        $(\"#chkRead\").on(\"click\", function () {\r\n          if ($(\"#chkRead\").is(\":checked\")) {\r\n            $(\".small_button_a.proceed-button\").removeClass(\r\n              \"disabled-checkbox\"\r\n            );\r\n          } else {\r\n            $(\".small_button_a.proceed-button\").addClass(\"disabled-checkbox\");\r\n          }\r\n        });\r\n      }\r\n    }, 100);\r\n  }\r\n\r\n  /* Force Basket Login */\r\n  function forceBasketLogin() {\r\n    if ($eSRO.currentScreen === \"order.aspx\") {\r\n      if ($eSRO.isClientLogedIn == false) {\r\n        login();\r\n      }\r\n    }\r\n  }\r\n\r\n  /* Force Address Collection */\r\n  function forceAddressCollection() {\r\n    if ($eSRO.currentScreen === \"order.aspx\") {\r\n      setTimeout(function () {\r\n        if (\r\n          $eSRO.isClientLogedIn == true &&\r\n          $(\"#paymentPromptMessages ul li:contains('Oh no, looks like')\")\r\n            .length >= 1\r\n        ) {\r\n          window.location.replace(\r\n            window.location.protocol +\r\n              \"//\" +\r\n              window.location.host +\r\n              \"/CrmDetails.aspx#needsAddress\"\r\n          );\r\n        }\r\n      }, 250);\r\n    } else {\r\n      setTimeout(function () {\r\n        if (\r\n          $eSRO.currentScreen === \"crmdetails.aspx\" &&\r\n          window.location.hash === \"#needsAddress\"\r\n        ) {\r\n          doCommand(\r\n            event,\r\n            \"eSRO.Crm.PersonalDetailsView\",\r\n            \"cEditPersonalDetails\"\r\n          );\r\n        }\r\n      }, 500);\r\n    }\r\n  }\r\n\r\n  /* Ticket collection default */\r\n  function ticketCollectionForceDefault(params) {\r\n    if (\r\n      $eSRO.currentScreen === \"delivery.aspx\" ||\r\n      $eSRO.currentScreen === \"order.aspx\"\r\n    ) {\r\n      var functionCounter = setInterval(function () {\r\n        $(\".print-options-selector:not(.defaulted)\").each(function () {\r\n          if (\r\n            $(this).children(\"option[value='\" + params.default + \"']\").length >\r\n            0\r\n          ) {\r\n            $(this).val(params.default);\r\n            $(this).change();\r\n            $(this).addClass(\"defaulted\");\r\n            //remove empty option\r\n            $(this).children(\"option[value='']\").remove();\r\n          }\r\n        });\r\n      }, 100);\r\n    }\r\n  }\r\n\r\n  /* Seperate Registration Page */\r\n  function seperateRegistrationPage() {\r\n    $(\".flm_Join\").attr(\"onclick\", \"changeRegister()\");\r\n    $(document).on(\"dialogopen\", \".loginOrRegisterDlg\", function () {\r\n      $(\r\n        \".loginOrRegisterWizard #loginCtrlContainer div.linkToAlternative>button\"\r\n      ).attr(\"onclick\", \"changeRegister()\");\r\n    });\r\n  }\r\n\r\n  function changeRegister() {\r\n    window.location.replace(\"/crmcreateaccount.aspx\");\r\n  }\r\n\r\n  /* Hide Seasonal Hospitality Seat */\r\n  function hideSeasonalHosptialitySeat() {\r\n    if ($eSRO.currentScreen === \"subscriptionrenew.aspx\") {\r\n      $(\".subsRenewEntry\").each(function () {\r\n        if (\r\n          $(this)\r\n            .children(\".details\")\r\n            .children('.seriesName:contains(\"Hospitality\")').length >= 1\r\n        ) {\r\n          $(this).children(\".details\").children(\".seatLocation\").hide();\r\n        }\r\n      });\r\n    }\r\n  }\r\n\r\n  /* Remove More Info */\r\n  function removeMoreInfo() {\r\n    if ($eSRO.currentScreen === \"recommendedevents.aspx\") {\r\n      $(\".itemsList .dataItem .itemsButtonsContainer .moreInfo\").remove();\r\n    }\r\n  }\r\n\r\n  /* Default Check Ticket Schemes */\r\n  function defaultCheckTicketSchemes() {\r\n    if (\r\n      $eSRO.currentScreen === \"offers.aspx\" ||\r\n      $eSRO.currentScreen === \"order.aspx\"\r\n    ) {\r\n      var functionCounter = setInterval(function () {\r\n        $(\"#TicketSchemeSelections tbody tr\").each(function () {\r\n          if (\r\n            $(this).children(\"td\").children('input[type=\"checkbox\"]').length > 0\r\n          ) {\r\n            if (\r\n              $(this)\r\n                .children(\"td\")\r\n                .children('input[type=\"checkbox\"]')\r\n                .prop(\"checked\") == false\r\n            ) {\r\n              $(this).children(\"td\").children('input[type=\"checkbox\"]').click();\r\n            }\r\n          }\r\n          clearInterval(functionCounter);\r\n        });\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  /* Display Languages */\r\n  function displayLanguages() {\r\n    var applyCheck = 0;\r\n    var functionCounter = setInterval(function () {\r\n      if ($(\"#PH_SupportedCultures\").length > 0 && applyCheck != 1) {\r\n        $(\"#PH_SupportedCultures\").appendTo(\r\n          \"#PH_Float_Menu #siteMenuBar .siteMenuContainer\"\r\n        );\r\n        applyCheck = 1;\r\n      }\r\n    }, 100);\r\n  }\r\n\r\n  function customDataForm(params) {\r\n    $(\"body\").on(\"dialogopen\", function (e) {\r\n      if (e.target.id === \"itemsExtraDataDialog\") {\r\n        var dataform = $(e.target).find(\"form\")[0];\r\n        var formName = dataform.name;\r\n        var isCustomDataForm = false;\r\n\r\n        if (params.formNames.length > 0) {\r\n          $.each(params.formNames, function (index, value) {\r\n            if (value === formName) isCustomDataForm = true;\r\n          });\r\n        }\r\n        $(\"#btnFinish\").text(\"Submit\");\r\n        $(\"#btnNext\").text(\"Apply\");\r\n        $(\"#btnPrev\").hide();\r\n\r\n        $(\".basketManRow\").length === 1\r\n          ? $(\"#btnNext\").hide()\r\n          : $(\"#btnFinish\").hide();\r\n\r\n        if (!$(\".basketManRow.missing\").length > 0) $(\"#btnFinish\").show();\r\n\r\n        $(\"#btnNext\").click(() => {\r\n          if ($(\".simpleForm #itemsExtraDataDialog\").length == 0) {\r\n            if (\r\n              validateFormED($(\".itemExtraDataDialog input.mandatory\")) &&\r\n              $(\".basketManRow.missing\").length > 0\r\n            ) {\r\n              var windowWidth = $(window).width();\r\n              var idToUse =\r\n                windowWidth > 780\r\n                  ? $([document.documentElement, document.body])\r\n                  : $(\".itemExtraDataDialog\");\r\n              idToUse.animate(\r\n                {\r\n                  scrollTop: $(\"#itemExtraDataDialog\").offset().top,\r\n                },\r\n                1000\r\n              );\r\n            }\r\n          }\r\n        });\r\n\r\n        $(\"#btnNext, .basketManRow\").click(() => {\r\n          $(\"#btnNext\").attr(\"disabled\", false);\r\n          if (typeof dataform !== \"undefined\" && hasFormReset()) {\r\n            console.log(\"resetting form\");\r\n            resetFormED($(dataform));\r\n          }\r\n          if (!$(\".basketManRow.missing\").length > 0) $(\"#btnFinish\").show();\r\n        });\r\n\r\n        /* Extra Data Forms */\r\n        function resetFormED($form) {\r\n          var inputs = $form.find(\"input:not(:disabled), select:not(:disabled)\");\r\n          var checkedInputs = inputs.filter((i,e)=>$(e).is(\"[type=radio]\"));\r\n          inputs.not(checkedInputs).val(\"\");\r\n          checkedInputs.prop(\"checked\", false);\r\n        }\r\n\r\n        function validateFormED($formFields) {\r\n          var isValid = true;\r\n          $formFields.each(function () {\r\n            if ($(this).val() === \"\") isValid = false;\r\n          });\r\n          return isValid;\r\n        }\r\n\r\n        function hasFormReset() {\r\n          return (\r\n            $(\".basketManRow.missing.selected\").length > 0 &&\r\n            validateFormED($(\".itemExtraDataDialog input.mandatory\")) &&\r\n            (isCustomDataForm || params.clearFieldsOnAllForms)\r\n          );\r\n        }\r\n      }\r\n    });\r\n  }\r\n\r\n  /* Hide Edit Profile for Company Account */\r\n  function hideEditProfileForCompanyAccount() {\r\n    if ($eSRO.currentScreen == \"crmdetails.aspx\" && $eSRO.clientIsAccount) {\r\n      setTimeout(function () {\r\n        $(\".cEditPersonalDetails\").hide();\r\n      }, 500);\r\n    }\r\n  }\r\n\r\n  /* Resale Page */\r\n  function resalePage() {\r\n    if ($eSRO.currentScreen === \"resale.aspx\") {\r\n      $(\"#PH_\").append('<div class=\"resale-wrapper\"><div>');\r\n      var resaleCounter = setInterval(function () {\r\n        //if($('#PH_ #alertItems').length === 0){\r\n        if ($(\"#PH_ .crmAlertItems\").length === 0) {\r\n          //$(\"#alertItems\").prependTo(\"#PH_ .resale-wrapper\");\r\n          $(\".crmAlertItems\").prependTo(\"#PH_ .resale-wrapper\");\r\n          $(\".ui-dialog-buttonpane:not(.showPopupMessage-buttonpane)\").appendTo(\r\n            \"#PH_\"\r\n          );\r\n          $(\"body > .crmAlertItems\").hide();\r\n        }\r\n      }, 10);\r\n    }\r\n  }\r\n\r\n  /* Resale Welcome Panel */\r\n  function resalePanel(params) {\r\n    if ($eSRO.currentScreen === \"crmdetails.aspx\") {\r\n      var Counter = setInterval(function () {\r\n        if (\r\n          $(\".resale-alert\").length > 0 &&\r\n          !$(\"#resale-welcome-panel\").length > 0\r\n        ) {\r\n          //clearInterval(Counter);\r\n          $(\".resale-alert\").parent().parent().remove();\r\n          $(\"#crmWelcomeLeft\").prepend(params.content);\r\n          $(\"body\").addClass(\"resale-available\");\r\n        }\r\n        if ($(\"#crmAlertsContent > div\").length > 0) {\r\n          $(\"#crmAlerts\").removeClass(\"hiddenPixel\");\r\n        } else {\r\n          $(\"#crmAlerts\").addClass(\"hiddenPixel\");\r\n        }\r\n      }, 10);\r\n    }\r\n  }\r\n\r\n  /* Direct Click to Dashboard */\r\n  function eCRMDirect() {\r\n    $(document).on(\"tooltipshow\", function (e) {\r\n      if ($(e.target).is(\".crmInfoMenuTooltip\")) {\r\n        e.preventDefault();\r\n      }\r\n    });\r\n\r\n    $(\"#customerBox a\").on(\"click\", function (e) {\r\n      window.location = \"crmdetails.aspx\";\r\n    });\r\n    $(\"#customerBox a\").addClass(\"eCRMDirect\");\r\n  }\r\n\r\n  /* Next Event Panel */\r\n  function nextEventPanel(params) {\r\n    if ($eSRO.currentScreen === \"crmdetails.aspx\") {\r\n      var Counter = setInterval(function () {\r\n        if (\r\n          $(\"#crmNextEvent\").length > 0 &&\r\n          !$(\"#crmWelcomeLeft #crmNextEvent\").length > 0\r\n        ) {\r\n          $(\"#crmNextEventLinks\").append(params.content);\r\n          $(\"#crmNextEvent\").prependTo(\"#crmWelcomeLeft\");\r\n        }\r\n        if (\r\n          params.addOns &&\r\n          !$(\"#add-ons-button\").length > 0 &&\r\n          $(\"#crmNextEventContent #date\").text() != \"\"\r\n        ) {\r\n          var dateText = $(\"#crmNextEventContent #date\").text();\r\n          console.log(dateText);\r\n          dateText = dateText.substring(0, dateText.indexOf(\" \"));\r\n          console.log(dateText);\r\n          var dateTextarray = dateText.split(\"/\");\r\n          var dateTextButton =\r\n            '<a id=\"add-ons-button\" href=\"/calendar/' +\r\n            dateTextarray[2] +\r\n            \"-\" +\r\n            dateTextarray[1] +\r\n            \"-\" +\r\n            dateTextarray[0] +\r\n            '\">Add-Ons</a>';\r\n          $(\"#crmNextEventLinks\").append(dateTextButton);\r\n        }\r\n      }, 10);\r\n    }\r\n  }\r\n  /* Payment Page with no Payment */\r\n\r\n  function zeroPayment(params) {\r\n    if ($eSRO.currentScreen === \"checkout.aspx\") {\r\n      if ($(\"button.proceed:contains('Submit')\").length > 0) {\r\n        $(\".pageSectionTitle\").html(params.text);\r\n      }\r\n    }\r\n  }\r\n\r\n  /* Forward Strong Relationips */\r\n\r\n  function forwardStrongRelationships() {\r\n    //Ajax Request Complete\r\n    $(document).ajaxComplete(function () {\r\n      forwardStrongRelationshipRun();\r\n    });\r\n\r\n    function forwardStrongRelationshipRun() {\r\n      if ($eSRO.currentScreen == \"crmdetails.aspx\") {\r\n        setTimeout(function () {\r\n          var checkFor = relatedClientsList ? relatedClientsList : [];\r\n          var mr_id = $eSRO.client.id ? $eSRO.client.id : \"\";\r\n          if (\r\n            $(\r\n              \"[data-screenname*='eSRO.Crm.Ticketing.ChangeClientTicketsOwner'] .spScreenContent table tr\"\r\n            ).length\r\n          ) {\r\n            $(\r\n              \"[data-screenname*='eSRO.Crm.Ticketing.ChangeClientTicketsOwner'] .spScreenContent table tr\"\r\n            ).each(function (e) {\r\n              var thisRowIDs = $(this).find(\r\n                \"td.crm_grid_data.ChangeOwnershipLink span button\"\r\n              )[0]\r\n                ? $(this).find(\r\n                    \"td.crm_grid_data.ChangeOwnershipLink span button\"\r\n                  )[0]\r\n                : \"\";\r\n              var thisRowAccept = $(this)\r\n                .find(\"td.crm_grid_data.isAvailableForChangeOfOwnership span\")\r\n                .html()\r\n                ? $(this)\r\n                    .find(\r\n                      \"td.crm_grid_data.isAvailableForChangeOfOwnership span\"\r\n                    )\r\n                    .html()\r\n                : \"False\";\r\n              var thisRowSeries = $(this)\r\n                .find(\"td.crm_grid_data.SubscriberTicketType span\")\r\n                .html()\r\n                ? $(this)\r\n                    .find(\"td.crm_grid_data.SubscriberTicketType span\")\r\n                    .html()\r\n                : \"\";\r\n              $(this)\r\n                .find(\"td.crm_grid_data.ClientId span\")\r\n                .each(function (e, value) {\r\n                  var thisRowID = $(this).data(\"datavalue\");\r\n                  if (\r\n                    checkFor.find(\r\n                      (x) =>\r\n                        x.ClientId == thisRowID &&\r\n                        x.IsStrong == true &&\r\n                        thisRowAccept == \"True\"\r\n                    )\r\n                  ) {\r\n                    $(thisRowIDs).attr(\"disabled\", false);\r\n                  } else {\r\n                    return;\r\n                  }\r\n                });\r\n            });\r\n          }\r\n        }, 750);\r\n      }\r\n    }\r\n  }\r\n\r\n  /* Donations description from feed */\r\n  function getDonationDescription() {\r\n    if ($eSRO.currentScreen === \"donation.aspx\") {\r\n      getFeedData(\r\n        \"Donations\",\r\n        $('input[name=\"id\"]').val(),\r\n        \"DetailOverview\",\r\n        function (result) {\r\n          $(\".content\").append(`<div class=\"overview\">${result}</div>`);\r\n        }\r\n      );\r\n    }\r\n  }\r\n\r\n  function getGiftVoucherImage() {\r\n    if ($eSRO.currentScreen === \"giftvoucher.aspx\") {\r\n      getFeedData(\r\n        \"GiftVouchers\",\r\n        $('input[name=\"id\"]').val(),\r\n        \"LargeImage\",\r\n        function (result) {\r\n          $(\".content\").append(\r\n            `<div class=\"item_image\"><img class=\"item_image mainImage\" src=\"${result}\"></div>`\r\n          );\r\n        }\r\n      );\r\n      getFeedData(\r\n        \"GiftVouchers\",\r\n        $('input[name=\"id\"]').val(),\r\n        \"DetailOverview\",\r\n        function (result) {\r\n          $(\".content\").append(`<div class=\"overview\">${result}</div>`);\r\n        }\r\n      );\r\n    }\r\n  }\r\n\r\n  function getFeedData(feedName, id, returnType, callback) {\r\n    // Creating the singular form by removing the last character from the feed name\r\n    var singularForm = feedName.slice(0, -1);\r\n\r\n    $.getJSON(`/feed/${feedName.toLowerCase()}?json&full`, function (data) {\r\n      var items = data.feed[feedName][singularForm];\r\n      var matchedItem;\r\n\r\n      // Check if items is an array\r\n      if (Array.isArray(items)) {\r\n        for (var i = 0; i < items.length; i++) {\r\n          if (items[i].Id === id) {\r\n            matchedItem = items[i];\r\n            break;\r\n          }\r\n        }\r\n      } else if (items.Id === id) {\r\n        // if there's only one item\r\n        matchedItem = items;\r\n      }\r\n\r\n      if (matchedItem) {\r\n        callback(matchedItem[returnType]);\r\n      } else {\r\n        console.log(`No item found with ID: ${id} in ${feedName}`);\r\n        callback(null);\r\n      }\r\n    });\r\n  }\r\n\r\n  function redirectContinueCategoryVisited(params) {\r\n    // Check if the word 'categories' is present in the URL\r\n    if (\r\n      window.location.href.indexOf(\"categories\") !== -1 ||\r\n      (params &&\r\n        params.pages &&\r\n        Array.isArray(params.pages) &&\r\n        params.pages.some((page) => $eSRO.currentScreen === page))\r\n    ) {\r\n      // Set a cookie that expires in 7 days, storing the current URL\r\n      document.cookie =\r\n        \"lastVisitedCategory=\" +\r\n        encodeURIComponent(window.location.href) +\r\n        \";path=/; max-age=\" +\r\n        60 * 60 * 24 * 7;\r\n    }\r\n\r\n    // Function to get the last visited category URL\r\n    function getLastVisitedCategory() {\r\n      var match = document.cookie.match(\r\n        new RegExp(\"(^| )\" + \"lastVisitedCategory\" + \"=([^;]+)\")\r\n      );\r\n      return match ? decodeURIComponent(match[2]) : null;\r\n    }\r\n\r\n    // When the 'continue shopping' button is clicked, redirect to the last visited category URL\r\n    $(document).ready(function () {\r\n      console.log(`last Category Page: ${getLastVisitedCategory()}`);\r\n      $(\"#btnContinue\").click(function (e) {\r\n        e.preventDefault();\r\n        var url = getLastVisitedCategory();\r\n        if (url) {\r\n          window.location.href = url;\r\n        } else {\r\n          // Redirect to a default URL if no category URL has been visited\r\n          window.location.href = \"/\";\r\n        }\r\n      });\r\n    });\r\n  }\r\n\r\n  function addResaleButton() {\r\n    if ($eSRO.currentScreen === \"crmdetails.aspx\") {\r\n      $(document).on(\"tabsload\", function (e, i) {\r\n        if (\r\n          $(i.tab[0]).find(\"a#eSRO_Crm_ActiveTickets\") &&\r\n          $(\"button.Resale\").length === 0\r\n        ) {\r\n          $(\r\n            'div[data-screenname=\"eSRO.Crm.Ticketing.ClientTicketsRowGrid\"] .toolbar'\r\n          ).prepend(\r\n            '<a class=\"button Resale\" onclick=\"window.location.replace(\\'/resale.aspx\\')\"><span>Resale Tickets</span></a>'\r\n          );\r\n        }\r\n      });\r\n    }\r\n  }\r\n\r\n  function crmMobileScrollTicketButtons(params) {\r\n    if ($eSRO.currentScreen === \"crmdetails.aspx\" && $(window).width() < 781) {\r\n      var resaleAppended = false;\r\n      $(document).ready(function () {\r\n        $(document).on(\"tabsload\", function (event, ui) {\r\n          console.log(\"tabsload\");\r\n          var Counter = setInterval(function () {\r\n            if ($(\"#PH_CRM_details_page #leftMenu>ul>li\").length > 0) {\r\n              clearInterval(Counter);\r\n              if (!resaleAppended && params.showResale)\r\n                $(\"#PH_CRM_details_page #leftMenu>ul\").append(\r\n                  '<li role=\"tab\" tabindex=\"-1\" class=\"ui-tabs-tab ui-state-default ui-tab ui-corner-left\" aria-controls=\"ui-id-6\" aria-labelledby=\"eSRO_Crm_Resale\" aria-selected=\"false\" aria-expanded=\"false\"><a id=\"eSRO_Crm_Resale\" href=\"/resale.aspx\" role=\"presentation\" tabindex=\"-1\" class=\"ui-tabs-anchor\" data-ol-has-click-handler=\"\">Resale</a></li>'\r\n                );\r\n              resaleAppended = true;\r\n            }\r\n          }, 10);\r\n          if ($(ui.tab[0]).find(\"a#eSRO_Crm_ActiveTickets\").length > 0)\r\n            setupToolbar();\r\n        });\r\n\r\n        setupToolbar();\r\n\r\n        function setupToolbar() {\r\n          var toolbar = $(\".toolbar\");\r\n          var container = $(\".crm_screen_container\");\r\n          var startPosition = toolbar.offset().top;\r\n          var footerPosition = $(\"#PH_CustomFooter\").offset().top;\r\n\r\n          var observer = new MutationObserver(function (mutations) {\r\n            mutations.forEach(function (mutation) {\r\n              if (mutation.attributeName === \"class\") {\r\n                updateButtonVisibility();\r\n              }\r\n            });\r\n          });\r\n\r\n          toolbar.find(\"a.button\").each(function () {\r\n            observer.observe(this, {\r\n              attributes: true,\r\n            });\r\n          });\r\n\r\n          toolbar.addClass(\"fixed-buttons\");\r\n          container.addClass(\"initial\");\r\n\r\n          $(window).scroll(function () {\r\n            var scrollPosition = $(window).scrollTop();\r\n            if (scrollPosition <= 45) {\r\n              //toolbar.css(\"top\", 90 - scrollPosition);\r\n              container.addClass(\"initial\");\r\n              //updateButtonVisibility();\r\n            } else {\r\n              toolbar.css(\"top\", \"44px\");\r\n              container.removeClass(\"initial\");\r\n              updateButtonVisibility();\r\n            }\r\n\r\n            if (\r\n              scrollPosition >\r\n              $(\"#group_Footer\").offset().top - $(window).height()\r\n            ) {\r\n              toolbar.css(\"visibility\", \"hidden\");\r\n            } else {\r\n              toolbar.css(\"visibility\", \"visible\");\r\n            }\r\n          });\r\n\r\n          // Initial update to make sure the hidden class is applied correctly\r\n          var waitForDownloadButton = setInterval(function () {\r\n            if (toolbar.find(\"a.showNfcDetails\").length > 0) {\r\n              clearInterval(waitForDownloadButton);\r\n              updateButtonVisibility();\r\n            }\r\n          }, 100);\r\n\r\n          function changeText() {\r\n            toolbar.find(\"a.cChangeTicketOwner\").text(params.forward.small);\r\n            toolbar.find(\"a.cTurnback\").text(params.donate.small);\r\n            toolbar.find(\"a.showNfcDetails\").text(params.download.small);\r\n            if (params.showResale)\r\n              toolbar.find(\"a.Resale\").text(params.resale.small);\r\n          }\r\n\r\n          function revertText() {\r\n            toolbar.find(\"a.cChangeTicketOwner\").text(params.forward.large);\r\n            toolbar.find(\"a.cTurnback\").text(params.donate.large);\r\n            toolbar.find(\"a.showNfcDetails\").text(params.download.large);\r\n            if (params.showResale)\r\n              toolbar.find(\"a.Resale\").text(params.resale.large);\r\n          }\r\n\r\n          function updateButtonVisibility() {\r\n            if (toolbar.hasClass(\"fixed-buttons\")) {\r\n              //toolbar.find(\"a.button.disabled\").addClass(\"hidden\");\r\n              //toolbar.find(\"a.button:not(.disabled)\").removeClass(\"hidden\");\r\n              // wait for download button to be available\r\n              changeText();\r\n            } else {\r\n              //toolbar.find(\"a.button\").removeClass(\"hidden\");\r\n              revertText();\r\n            }\r\n          }\r\n        }\r\n      });\r\n    }\r\n  }\r\n\r\n  function useTicketSchemesTerms() {\r\n    $(document).ready(function () {\r\n      if ($eSRO.currentScreen === \"offers.aspx\") {\r\n        var applyCheck = 0;\r\n        var functionCounter = setInterval(function () {\r\n          if ($(\".ticketSchemes-container\").length > 0 && applyCheck == 0) {\r\n            function loadPage(href) {\r\n              var xmlhttp = new XMLHttpRequest();\r\n              xmlhttp.open(\"GET\", href, false);\r\n              xmlhttp.send();\r\n              return xmlhttp.responseText;\r\n            }\r\n            var folders = window.location.pathname;\r\n            var lastSegment = folders.split(\"/\").pop();\r\n            var pathToLoad =\r\n              location.protocol +\r\n              \"//\" +\r\n              window.location.host +\r\n              \"/usercontent/documents\" +\r\n              $eSRO.siteBasePath +\r\n              \"html/ticketschemes-terms.html\";\r\n            $.ajax({\r\n              url: pathToLoad,\r\n              type: \"HEAD\",\r\n              success: function () {\r\n                document.getElementById(\"genrehtml\").innerHTML =\r\n                  '<div id=\"genrehtmlterms\">' + loadPage(pathToLoad) + \"</div>\";\r\n              },\r\n            });\r\n            applyCheck = 1;\r\n          }\r\n        }, 1000);\r\n      }\r\n    });\r\n  }\r\n\r\n  function removeStrongRelationshipRoles() {\r\n    $(document).ready(function () {\r\n      if (\r\n        $eSRO.currentScreen === \"order.aspx\" ||\r\n        $eSRO.currentScreen === \"crmdetails.aspx\"\r\n      ) {\r\n        var modalCounter = setInterval(function () {\r\n          if ($(\".myDialog\").dialog(\"isOpen\")) {\r\n            $(\".relationshipType\").on(\"change\", function () {\r\n              if (\r\n                $(this).val() == \"30000000-0000-0000-0000-000000000001\" ||\r\n                $(\".relationshipType option:selected\").text() ==\r\n                  \"Strong Relationship\"\r\n              ) {\r\n                console.log(\"strong\");\r\n                $(\".relationshipRole\").attr(\"style\", \"display:none !important\");\r\n              } else {\r\n                console.log(\"standard\");\r\n                $(\".relationshipRole\").attr(\r\n                  \"style\",\r\n                  \"display:block !important\"\r\n                );\r\n              }\r\n            });\r\n          }\r\n        }, 1000);\r\n      }\r\n    });\r\n  }\r\n\r\n  function mandatoryTicketSchemesByName(params) {\r\n    if (\r\n      $eSRO.currentScreen === \"offers.aspx\" ||\r\n      $eSRO.currentScreen === \"order.aspx\"\r\n    ) {\r\n      $(\"body\").addClass(\"mandatoryTicketSchemes\");\r\n      var applyCheck = 0;\r\n      var functionCounter = setInterval(function () {\r\n        var i;\r\n        for (i = 0; i < params.quantity; i++) {\r\n          if ($(\"#fldIsSelected-_\" + i).length > 0) {\r\n            if ($(\"#fldIsSelected-_\" + i).prop(\"checked\") == false) {\r\n              $(\"#fldIsSelected-_\" + i).click();\r\n            }\r\n            $(\"#fldIsSelected-_\" + i).attr(\"disabled\", true);\r\n          }\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n\r\n  function spreedlyIframe(params) {\r\n    $(document).on(\"dialogopen\", \".newOpsTokenIframe\", function (e) {\r\n      $(\"#newTokenIframe\").on(\"load\", function () {\r\n        var timeStamp = Math.floor(Date.now() / 1000);\r\n        var $head = $(\"#newTokenIframe\").contents().find(\"head\");\r\n        //var url = \"/usercontent/core/spreedly.css\";\r\n        var url = \"/cus/release/css/core.css?v=\" + timeStamp;\r\n        var customcss = `/usercontent/${params.cssLocation}/spreedly.css?v=${timeStamp}`;\r\n\r\n        $head.append(\r\n          $(\"<link/>\", { rel: \"stylesheet\", href: url, type: \"text/css\" })\r\n        );\r\n        $head.append(\r\n          $(\"<link/>\", { rel: \"stylesheet\", href: customcss, type: \"text/css\" })\r\n        );\r\n\r\n        var myFrame = document.getElementById(\"newTokenIframe\");\r\n\r\n        myFrame.contentWindow.loadJs = function () {\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find('.sgs-form-h2:contains(\"Billing Address\")')\r\n            .hide();\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find(\".sgs-field-fullname > label\")\r\n            .text(\"Cardholder Name\");\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find(\"#spreedly-number-label\")\r\n            .text(\"CVV/CVC/CID\");\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find(\"label.sgs-field-group.sgs-number\")\r\n            .text(\"Credit/Debit Card Number\");\r\n\r\n          if (\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\"#sgs-payment-form > fieldset.sgs-fs-cc #sgs_ga_pay\")\r\n          ) {\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\"#sgs_ga_pay\")\r\n              .parent()\r\n              .css(\"order\", \"1\");\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\".sgs-fs-name\")\r\n              .css(\"order\", \"2\");\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find('.sgs-form-h2:contains(\"Billing Address\")')\r\n              .css(\"order\", \"3\");\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\".sgs-fs-address\")\r\n              .css(\"order\", \"4\");\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\"#spreedly-number\")\r\n              .parent()\r\n              .parent()\r\n              .css(\"order\", \"5\");\r\n\r\n            var paymentCounter = setInterval(function () {\r\n              if (\r\n                $(\"#newTokenIframe\")\r\n                  .contents()\r\n                  .find(\".sgs-form-h2:nth-of-type(3):not(.set)\") &&\r\n                $(\"#newTokenIframe\")\r\n                  .contents()\r\n                  .find(\"#sgs_cc_pay\")\r\n                  .prop(\"checked\") == false\r\n              ) {\r\n                $(\"#newTokenIframe\").contents().find(\"#sgs_cc_pay\").click();\r\n                $(\"#newTokenIframe\").contents().find(\"#sgs_cc_pay\").hide();\r\n                $(\"#newTokenIframe\")\r\n                  .contents()\r\n                  .find(\".sgs-form-h2:nth-of-type(3)\")\r\n                  .text(\"Add Credit/Debit Card\");\r\n                $(\"#newTokenIframe\")\r\n                  .contents()\r\n                  .find(\".sgs-form-h2:nth-of-type(3)\")\r\n                  .addClass(\"set\");\r\n              }\r\n            }, 1000);\r\n          }\r\n\r\n          if (\r\n            !$(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\"#sgs-payment-form > fieldset.sgs-fs-cc #sgs_ga_pay\")\r\n          ) {\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\"#spreedly-number\")\r\n              .parent()\r\n              .parent()\r\n              .css(\"order\", \"2\");\r\n            $(\"#newTokenIframe\")\r\n              .contents()\r\n              .find(\".sgs-fs-name\")\r\n              .css(\"order\", \"1\");\r\n          }\r\n\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find(\"#field_alternated.sgs-fs-cc\")\r\n            .hide();\r\n          $(\"#newTokenIframe\")\r\n            .contents()\r\n            .find(\"#field_alternated.sgs-fs-cc\")\r\n            .css(\"display\", \"none\");\r\n        };\r\n\r\n        document.getElementById(\"newTokenIframe\").contentWindow.loadJs();\r\n      });\r\n    });\r\n  }\r\n\r\n  // disables best available button on hall map for x ms after user clicks\r\n  function chooseSeatsForMeTimeout(params) {\r\n    $(\".areas-filter-panel__find-button\").click(function () {\r\n      var btn = $(this);\r\n      if (btn.hasClass(\"disabled\")) return;\r\n      else {\r\n        btn.addClass(\"disabled\");\r\n        setTimeout(function () {\r\n          btn.removeClass(\"disabled\");\r\n        }, params.timeoutMs);\r\n      }\r\n    });\r\n  }\r\n\r\n  // hide elements on a page based on the current URL, example: hideElementsPerPage({'.element': ['URlContains', 'URLContains']});\r\n  function hideElementsPerPage(params) {\r\n    var currentURL = window.location.href;\r\n\r\n    $.each(params.elements, function (selector, keywords) {\r\n      $.each(keywords, function (index, keyword) {\r\n        if (currentURL.includes(keyword)) {\r\n          $(selector).hide();\r\n          return false;\r\n        }\r\n      });\r\n    });\r\n  }\r\n\r\n  function eSROHeaderV2(params) {\r\n    $(\"body\").addClass(\"hide-crm-menu\");\r\n\r\n    function createNewAccountIcon() {\r\n      let initials;\r\n      \r\n      // Check if initials are available in $eSRO.client\r\n      if ($eSRO.client.initials) {\r\n        initials = $eSRO.client.initials;\r\n      } else {\r\n        // Fallback to name parsing if initials not available\r\n        const clientName = $eSRO.client.name;\r\n        let clientNameParts = clientName.match(/\\b[A-Za-z]+\\b/g);\r\n\r\n        if (clientNameParts && clientNameParts.length > 0) {\r\n          const titles = [\"mr\", \"mrs\", \"ms\", \"dr\", \"prof\"];\r\n\r\n          while (\r\n            clientNameParts.length > 1 &&\r\n            titles.includes(clientNameParts[0].toLowerCase())\r\n          ) {\r\n            clientNameParts.shift();\r\n          }\r\n\r\n          if (clientName.includes(\",\")) {\r\n            clientNameParts = clientNameParts.reverse();\r\n          }\r\n\r\n          const firstInitial = clientNameParts[0].charAt(0).toUpperCase();\r\n          const lastInitial = clientNameParts[clientNameParts.length - 1]\r\n            .charAt(0)\r\n            .toUpperCase();\r\n\r\n          initials = firstInitial + lastInitial;\r\n        } else {\r\n          initials = \"??\";\r\n        }\r\n      }\r\n\r\n      // Wait for the element to be available and then update the UI element with the initials\r\n      const observer = new MutationObserver(function (mutations, me) {\r\n        const element = document.querySelector(\r\n          \"#navMenu_Float_myAccount_item span\"\r\n        );\r\n        if (element) {\r\n          element.classList.add(\"initials\");\r\n          element.textContent = initials;\r\n\r\n          me.disconnect(); // Stop observing\r\n          return;\r\n        }\r\n      });\r\n\r\n      // Start observing the document for changes\r\n      observer.observe(document, {\r\n        childList: true,\r\n        subtree: true,\r\n      });\r\n    }\r\n\r\n    if ($eSRO.hasClient) {\r\n      createNewAccountIcon();\r\n    }\r\n  }\r\n\r\n  // Scoped to the payment / extras flow on mobile only, because other\r\n  // dialogs regressed when we locked the body globally. iOS Safari ignores\r\n  // overflow:hidden on body, so we use position:fixed + saved scrollTop.\r\n  // Check is deferred one tick so a close+open handoff (e.g. payment\r\n  // method picker -> Spreedly iframe) doesn't flash-unlock in between.\r\n  function preventBackgroundScroll() {\r\n    var TARGET_SELECTOR = \".newOpsTokenIframe, #newTokenIframe, #promptExtras-dialog, #payment-container\";\r\n    var MOBILE_MAX_WIDTH = 768;\r\n    var $html = $(\"html\");\r\n    var savedScrollY = 0;\r\n    var locked = false;\r\n\r\n    function isMobile() {\r\n      return window.matchMedia\r\n        ? window.matchMedia(\"(max-width: \" + MOBILE_MAX_WIDTH + \"px)\").matches\r\n        : window.innerWidth <= MOBILE_MAX_WIDTH;\r\n    }\r\n\r\n    function anyTargetOpen() {\r\n      var open = false;\r\n      $(TARGET_SELECTOR).each(function () {\r\n        if (!open && $(this).is(\":visible\")) open = true;\r\n      });\r\n      return open;\r\n    }\r\n\r\n    function applyLock() {\r\n      var shouldLock = isMobile() && anyTargetOpen();\r\n      if (shouldLock && !locked) {\r\n        savedScrollY = window.scrollY || window.pageYOffset || 0;\r\n        $html.addClass(\"dialog-scroll-locked\");\r\n        $(\"body\").css({\r\n          position: \"fixed\",\r\n          top: -savedScrollY + \"px\",\r\n          left: 0,\r\n          right: 0,\r\n          width: \"100%\",\r\n        });\r\n        locked = true;\r\n      } else if (!shouldLock && locked) {\r\n        $html.removeClass(\"dialog-scroll-locked\");\r\n        $(\"body\").css({\r\n          position: \"\",\r\n          top: \"\",\r\n          left: \"\",\r\n          right: \"\",\r\n          width: \"\",\r\n        });\r\n        window.scrollTo(0, savedScrollY);\r\n        locked = false;\r\n      }\r\n    }\r\n\r\n    $(document).on(\"dialogopen dialogclose\", function () {\r\n      setTimeout(applyLock, 0);\r\n    });\r\n  }\r\n\r\n  return {\r\n    addBodyClasses,\r\n    hideUnavailablePackages,\r\n    hospitalityUpsell,\r\n    nonSeatedMessage,\r\n    passwordReset,\r\n    nextMatch,\r\n    displayStadiumKey,\r\n    displaySeatKey,\r\n    replaceSeatMessageAndKey,\r\n    displayHospitalityPricing,\r\n    hideAvailabilitySeatQty,\r\n    promoBox,\r\n    voucherBox,\r\n    autoExpandAreaSelection,\r\n    filtersForCategoryPage,\r\n    autoCheckAssignOwners,\r\n    changeBasketSeatLocationHospitality,\r\n    hideMembershipsList,\r\n    hideSubscriptionList,\r\n    hideFriendsAndFamilyButtons,\r\n    mandatoryTicketSchemes,\r\n    ballotTerms,\r\n    forceBasketLogin,\r\n    forceAddressCollection,\r\n    ticketCollectionForceDefault,\r\n    seperateRegistrationPage,\r\n    changeRegister,\r\n    hideSeasonalHosptialitySeat,\r\n    removeMoreInfo,\r\n    defaultCheckTicketSchemes,\r\n    displayLanguages,\r\n    customDataForm,\r\n    hideEditProfileForCompanyAccount,\r\n    resalePage,\r\n    resalePanel,\r\n    eCRMDirect,\r\n    nextEventPanel,\r\n    zeroPayment,\r\n    forwardStrongRelationships,\r\n    getDonationDescription,\r\n    getGiftVoucherImage,\r\n    redirectContinueCategoryVisited,\r\n    crmMobileScrollTicketButtons,\r\n    useTicketSchemesTerms,\r\n    removeStrongRelationshipRoles,\r\n    mandatoryTicketSchemesByName,\r\n    spreedlyIframe,\r\n    preventBackgroundScroll,\r\n    addResaleButton,\r\n    chooseSeatsForMeTimeout,\r\n    hideElementsPerPage,\r\n    eSROHeaderV2,\r\n  };\r\n});\r\n"
