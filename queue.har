            "mimeType": "application/javascript",
            "text": "/**\n * default Settings\n *\n * sets the base template settings and acts as a feature flag\n */\n\ndefine(\"defaultSettings\", [], function () {\n\tvar defaultSettings = {\n\t\taddBodyClasses: {\n\t\t\tenabled: true,\n\t\t\t\"display-competition-crest\": false, // Display the competition crest on events\n\t\t\t\"display-availability\": false, // Display the availability of the event\n\t\t\t\"display-points-in-header\": false, // Display loyalty points in the header\n\t\t\t\"display-full-image-hospitality-packages\": false, // Display full image for hospitality packages\n\t\t\t\"display-user-icon\": false, // Display the user icon in the header\n\t\t\t\"display-basket-icon\": false, // Display the basket icon in the header\n\t\t\t\"display-basket-subtitles\": false, // Display the basket subtitles\n\t\t\t\"force-basket-assign-owner\": false, // Assign owner\n\t\t\t\"disable-renewal-price\": false, // Disable renewal price\n\t\t\t\"disable-dont-renew\": false, // Disable don't renew\n\t\t\t\"flip-seats\": false, // Flip seat icons, if seats are displaying facing the wrong direction\n\t\t\t\"disable-print-confirmation\": false, // Hide the print confirmation button\n\t\t\t\"enable-filter-spinner\": false, // Enable the filter spinner\n\t\t\t\"display-choose-seats-for-me\": false, // Display the choose seats for me button\n\t\t\t\"display-remove-all\": false, // Display the remove all button in the basket\n\t\t\t\"display-basket-summary\": false, // Display the basket summary on checkout\n\t\t\t\"disable-not-renew\": false, // Disable the not renew button\n\t\t\t\"desktop-ecrm-grid-as-cards\": false, // Display the desktop ecrm grid as cards\n\t\t\t\"display-next-event-icons\": false, // Display the next event icons\n\t\t\t\"display-sticky-basket-timer\": false, // Display the sticky basket timer\n\t\t\t\"display-memberships-list\": false, // Display the memberships list\n\t\t\t\"display-subscriptions-list\": false, // Display the subscriptions list\n\t\t\t\"useSROColours\": false, // Use SRO colours\n\t\t\t\"display-expanded-basket-summary\": false, // Display the expanded basket summary\n\t\t},\n\n\t\thideUnavailablePackages: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Add a hospitality prompt on the area selection (html)\n\t\thospitalityUpsell: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t\"For an unforgettable experience, <a href='/hospitality'>click here</a> to view the range of hospitality packages available for games played at Old Trafford.\",\n\t\t},\n\n\t\t// Add a message at the top of the ticket selection\n\t\tnonSeatedMessage: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t\"Season Ticket holders and Official Full or Premium Members who are personally attending the Museum & Tour can benefit from 50% off at checkout.\",\n\t\t\teventName: \"tour\",\n\t\t},\n\n\t\t// Seperate password reset page\n\t\tpasswordReset: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Next match landing page panel\n\t\tnextMatch: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Display stadium key (html)\n\t\tdisplayStadiumKey: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'<div class=\"leg\"><div class=\"legend available\"></div><div class=\"description\">Available</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div><div class=\"leg\"><div class=\"legend selected\"></div><div class=\"description\">Selected</div></div>',\n\t\t},\n\n\t\t// Display seat key (html)\n\t\tdisplaySeatKey: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'<div class=\"leg\"><div class=\"legend available\"></div><div class=\"description\">Available</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div><div class=\"leg\"><div class=\"legend selected\"></div><div class=\"description\">Selected</div></div>',\n\t\t},\n\n\t\t// Replace seat key (html)\n\t\treplaceSeatMessageAndKey: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'<div class=\"message-text\"><h2>Replace Seat</h2><p><b>Important: seat relocations are only available to supporters who took a 1-Year Break for 2021/22 or who were required to relocate from their seat.</b></p><p>Your current seat is shown in black below. You can relocate to any red seat and can click the “Show Stadium Map” button below to view areas with availability and navigate around blocks. Once you have selected a seat, click “OK” and follow instructions as prompted and complete your relocation. Any difference in cost will either be requested, or refunded accordingly. If you paid with V12 Retail Finance, the difference in cost of relocating to a more expensive seat will need to be paid for by card, and you will be unable to relocate to a less expensive seat.</p><p>If you wish to move seats for multiple supporters, you will need to complete this process separately for each ticket.</p></div>',\n\t\t\tkey: '<div class=\"leg\"><div class=\"legend available\"></div><div class=\"description\">Available</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div><div class=\"leg\"><div class=\"legend selected\"></div><div class=\"description\">Selected</div></div>',\n\t\t},\n\n\t\t// Display hospitality package pricing (price label)\n\t\tdisplayHospitalityPricing: {\n\t\t\tenabled: false,\n\t\t\tcontent: \"per person\",\n\t\t},\n\n\t\t// Hide Available Seat Qty\n\t\thideAvailabilitySeatQty: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Filters for Category Page\n\t\tfiltersForCategoryPage: {\n\t\t\tenabled: false,\n\t\t\tfilterBy: \"Filter by\",\n\t\t\tcompetition: \"Competition\",\n\t\t\tseason: \"Season\",\n\t\t\tdate: \"Date\",\n\t\t\tvenue: \"Venue\",\n\t\t\topposition: \"Opposition\",\n\t\t\treset: \"Reset\",\n\t\t},\n\n\t\t// Auto Expand Area Selection\n\t\tautoExpandAreaSelection: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Promo Box (description, link)\n\t\tpromoBox: {\n\t\t\tenabled: false,\n\t\t\tdescription: \"Do you have a promotion code?\",\n\t\t\tlink: \"I have a promo code\",\n\t\t},\n\n\t\t// Gift Voucher Box (description, link)\n\t\tvoucherBox: {\n\t\t\tenabled: false,\n\t\t\tdescription: \"Do you have a gift voucher?\",\n\t\t\tlink: \"I have a gift voucher\",\n\t\t},\n\n\t\t// Auto Check Assign Owners\n\t\tautoCheckAssignOwners: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Mandatory Ticket Schemes (number of schemes)\n\t\tmandatoryTicketSchemes: {\n\t\t\tenabled: false,\n\t\t\tnumber: 2,\n\t\t},\n\n\t\t// Change Basket Seat Location for Hospitality\n\t\tchangeBasketSeatLocationHospitality: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Hide Subscription List\n\t\thideSubscriptionList: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Hide Memberships List\n\t\thideMembershipsList: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Ballots Terms\n\t\tballotTerms: {\n\t\t\tenabled: false,\n\t\t\tdescription: \"I have read and agree to the\",\n\t\t\tlinkText: \"terms and conditions and supporter code of conduct\",\n\t\t\tlink: \"https://www.manutd.com/en/help/terms-and-conditions-of-sale\",\n\t\t},\n\n\t\t// Force Basket Login\n\t\tforceBasketLogin: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Force Address Collection\n\t\tforceAddressCollection: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Ticket collection default to email\n\t\tticketCollectionForceDefault: {\n\t\t\tenabled: false,\n\t\t\tdefault: \"email_pah_ticket\",\n\t\t},\n\n\t\tresetFormED: {\n\t\t\tenabled: false,\n\t\t\t$form: $(\"#extraDataForm_name\"),\n\t\t},\n\n\t\t// Remove More Info\n\t\tremoveMoreInfo: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Default Check Ticket Schemes\n\t\tdefaultCheckTicketSchemes: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Seperate Registration Page\n\t\tseperateRegistrationPage: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Hide Seasonal Hospitality Seat\n\t\thideSeasonalHosptialitySeat: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Display Languages\n\t\tdisplayLanguages: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Culture Selector in top bar\n\t\tcultureSelectorTopBar: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\tforwardStrongRelationships: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Custom extra data forms function takes an array of form names and/or a bool to say use on all forms\n\t\tcustomDataForm: {\n\t\t\tenabled: false,\n\t\t\tformNames: [\"extraDataForm_name\"],\n\t\t\tclearFieldsOnAllForms: false,\n\t\t},\n\n\t\t// Hide Edit Profile for Company Account\n\t\thideEditProfileForCompanyAccount: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Resale Page\n\t\tresalePage: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Resale Welcome Panel\n\t\tresalePanel: {\n\t\t\tenabled: false,\n\t\t\tcontent:\n\t\t\t\t'<div id=\"resale-welcome-panel\"><h2>Ticket Cancellation</h2><div id=\"ticketExchangeContent\" class=\"welcomeContent\">If you can\\'t to attend a home game, you can request to cancel your ticket here<br /><br /><a class=\"landing-button primary\" href=\"resale.aspx\">Cancel Ticket</a></div></div>',\n\t\t},\n\n\t\t// Direct Click to Dashboard\n\t\teCRMDirect: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\t// Next Event Panel\n\t\tnextEventPanel: {\n\t\t\tenabled: false,\n\t\t\taddOns: true,\n\t\t\tcontent: '<a class=\"next-event-resale\" href=\"resale.aspx\">Cancel Ticket</a>',\n\t\t},\n\n\t\tzeroPayment: {\n\t\t\tenabled: false,\n\t\t\ttext: \"Terms of Sale\",\n\t\t},\n\n\t\tgetDonationDescription: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\tgetGiftVoucherImage: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\tredirectContinueCategoryVisited: {\n\t\t\tenabled: false,\n\t\t\tpages: [\"hospitalityevents.aspx\", \"membershipslist.aspx\", \"ballots.aspx\", \"subscriptionlist.aspx\", \"crmdetails.aspx\"]\n\t\t},\n\n\t\taddResaleButton: {\n\t\t\tenabled: true,\n\t\t},\n\n\t\tcrmMobileScrollTicketButtons: {\n\t\t\tenabled: false,\n\t\t\tshowResale: true,\n\t\t\tforward: {\n\t\t\t\tsmall: \"Forward\",\n\t\t\t\tlarge: \"Forward / Upgrade Ticket\",\n\t\t\t},\n\t\t\tdonate: {\n\t\t\t\tsmall: \"Donate\",\n\t\t\t\tlarge: \"Donate Ticket\",\n\t\t\t},\n\t\t\tdownload: {\n\t\t\t\tsmall: \"Download\",\n\t\t\t\tlarge: \"Add to mobile wallet\",\n\t\t\t},\n\t\t\tresale: {\n\t\t\t\tsmall: \"Resale\",\n\t\t\t\tlarge: \"Resale Tickets\",\n\t\t\t},\n\t\t},\n\n\t\tuseTicketSchemesTerms: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\tremoveStrongRelationshipRoles: {\n\t\t\tenabled: false,\n\t\t},\n\n\t\thideFriendsAndFamilyButtons: {\n\t\t\tenabled: false,\n\t\t\thideAddFamily: false,\n\t\t\thideFind: false,\n\t\t\thideAddFriend: false,\n\t\t},\n\n\t\tmandatoryTicketSchemesByName: {\n\t\t\tenabled: false,\n\t\t\tquantity: 2,\n\t\t},\n\t\tspreedlyIframe: {\n\t\t\tenabled: false,\n\t\t\tcssLocation: \"mufc.css\",\n\t\t},\n\t\tpreventBackgroundScroll: {\n\t\t\tenabled: true,\n\t\t},\n\t\tchooseSeatsForMeTimeout: {\n\t\t\tenabled: true,\n\t\t\ttimeoutMs: 5000,\n\t\t},\n\t\thideElementsPerPage: {\n\t\t\tenabled: false,\n\t\t\telements: {'':[]},\n\t\t},\n\t\teSROHeaderV2: {\n\t\t\tenabled: false,\n\t\t\tdesktopToMobileOffset: 220, // Offset for when to switch to mobile menu\n\t\t\tmobileMenuLocation: \"\", // class or id of the element where mobile menu will be placed after\n\t\t\tdesktopMenuLocation: \"#PH_Menu\", // class or id of the element where desktop menu will be placed after\n\t\t\tdirectClick: false, // Direct click to crmdetails/my-account\n\t\t}\n\t};\n\n\treturn defaultSettings;\n});\n"
