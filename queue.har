(\".details\").children(\".membershipName\").text() === \"Red Squad MembershipX\"\r\n\t\t\t\t\t) {\r\n\t\t\t\t\t\t$(this).children(\".newMembership\").children(\"span:nth-of-type(2)\").hide();\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t\t$(\".itemsToUpdate .listContainer .item .itemName\").each(function () {\r\n\t\t\t\t\t//Full Membership\r\n\t\t\t\t\tif ($(this).text() === \"All Red Full Membership\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000051}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//International Membership\r\n\t\t\t\t\tif ($(this).text() === \"International Membership\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000052}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//Light Membership\r\n\t\t\t\t\tif ($(this).text() === \"All Red Light Membership\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000053}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//Teen Red Membership\r\n\t\t\t\t\tif ($(this).text() === \"All Red Junior Membership (13 to 16 years old)\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000054}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//Red Squad Membership\r\n\t\t\t\t\tif ($(this).text() === \"All Red Junior Membership (9-12 years old)\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000055}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//Mighty Red Membership\r\n\t\t\t\t\tif ($(this).text() === \"All Red Junior Membership (4 to 8 years old)\") {\r\n\t\t\t\t\t\t$(this).append(`<div class=\"custom-caption\">${captions.Custom_7000056}</div>`);\r\n\t\t\t\t\t}\r\n\t\t\t\t\t//Premium Membership\r\n\t\t\t\t\tif ($(this).text() === \"Premium Membership\") {\r\n\t\t\t\t\t\t$(this).append(\r\n\t\t\t\t\t\t\t`<div class=\"custom-caption\">Welcome pack will include premium box, hardback book in sleeve, PU washbag, fashion scarf and pin badge set in box. Plus full access to LFCTV Go.</div>`\r\n\t\t\t\t\t\t)