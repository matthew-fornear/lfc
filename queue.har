          "content": {
            "size": 778,
            "mimeType": "application/javascript",
            "text": "define('settingsUtil', ['defaultSettings', 'clientSettings'], function (defaultSettings, clientSettings) {\r\n    function mergeSettings() {\r\n        const merge = (defaultSettings, clientSettings) => {\r\n            let result = {...defaultSettings};\r\n\r\n            Object.keys(clientSettings).forEach(key => {\r\n                if (clientSettings[key] instanceof Object && key in defaultSettings) {\r\n                    result[key] = merge(defaultSettings[key], clientSettings[key]);\r\n                } else {\r\n                    result[key] =clientSettings[key];\r\n                }\r\n            });\r\n\r\n            return result;\r\n        };\r\n\r\n        return merge(defaultSettings, clientSettings);\r\n    }\r\n\r\n    return {\r\n        mergeSettings: mergeSettings\r\n    };\r\n    \r\n});"
          },
          "redirectURL": "",
