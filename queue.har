            "text": "$(document).ready(function () {\r\n\tvar timeStamp = Math.floor(Date.now() / 1000);\r\n\tconsole.log(\"bespokestyle.js Loaded ver=\" + timeStamp);\r\n});\r\n\r\n$(document).ready(function () {\r\n\tif ($eSRO.currentScreen === \"checkout.aspx\" && $('.eventDetails .name:contains(\"Billy Joel\")').length > 0) {\r\n\t\t$(\"#terms-accept label\").html(\r\n\t\t\t'I have read and agree to the <a id=\"aTerms\" target=\"_blank\" href=\"https://www.liverpoolfc.com/legal/liverpool-football-club-terms-and-conditions\">Terms and Conditions</a> and the <a target=\"_blank\" href=\"https://www.liverpoolfc.com/legal/event-terms-and-conditions\">Event Terms & Conditions</a>'\r\n\t\t);\r\n\t}\r\n});\r\n\r\nif ($eSRO.currentScreen === \"ballots.aspx\" || $eSRO.currentScreen === \"ballotapplication.aspx\") {\r\n\t// Redirect to the new /tickets/ballots experience  (AH)\r\n\twindow.location.href = \"/tickets/ballots\";\r\n}\r\n\r\n$(document).ready(function () {\r\n\tif ($eSRO.currentScreen === \"confirmation.aspx\" || $eSRO.currentScreen === \"opsconfirmation.aspx\") {\r\n\t\t// Detect viewport width \r\n\t\tvar vw = Math.max(document.documentElement.clientWidth || 0, window.innerWidth || 0);\r\n\t\tvar isMobile = vw < 768;\r\n\r\n\t\t// Desktop settings\r\n\t\tvar desktopImageUrl = \"https://liverpoolfc.seatgeekenterprise.com/weblink/10004/get.resource/images/2057/1000975.jpg\";\r\n\t\tvar desktopHref = \"https://prf.hn/l/78w3ZJA/\";// Replace if needed with desktop-specific Expedia link\r\n\r\n\t\t// Mobile settings\r\n\t\tvar mobileImageUrl = \"https://liverpoolfc.seatgeekenterprise.com/weblink/10004/get.resource/images/2057/1000976.jpg\";\r\n\t\tvar mobileHref = \"https://prf.hn/l/jXM8ll0/\";  // Replace if needed with mobile-specific Expedia link\r\n\r\n\t\t// Choose appropriate settings based on viewport\r\n\t\tvar imageUrl = isMobile ? mobileImageUrl : desktopImageUrl;\r\n\t\tvar hrefUrl = isMobile ? mobileHref : desktopHref;\r\n\r\n\t\t$(\".confirmationMessageContainer\").after(\r\n\t\t\t'<div class=\"expedia\"><div><a href=\"' + hrefUrl + '\" target=\"_blank\"><img src=\"' + imageUrl + '\" style=\"max-width: 100%; height: auto; display: block;\"/></a></div></div>'\r\n\t\t);\r\n\t}\r\n});\r\n\r\nif ($eSRO.currentInterface == \"9\" || $eSRO.currentInterface == \"10\") {\r\n\t/*///////////*/\r\n\t/* Functions */\r\n\t/*///////////*/\r\n\r\n\t$(document).ready(function () {\r\n\t\t/* Scroll Position */\r\n\r\n\t\t$(window).scroll(function () {\r\n\t\t\tif ($(window).scrollTop() >= 20) {\r\n\t\t\t\t$(\"body\").addClass(\"twenty\");\r\n\t\t\t} else {\r\n\t\t\t\t$(\"body\").removeClass(\"twenty\");\r\n\t\t\t}\r\n\t\t});\r\n\r\n\t\t/* Cant add F&F Client Type */\r\n\r\n\t\tif ($(\"body\").hasClass(\"client-has-type-CantaddFriendsandFamily\")) {\r\n\t\t\tvar functionCounter = setInterval(function () {\r\n\t\t\t\t$(\"#editRelationshipsContainer a.create\").remove();\r\n\t\t\t\t$(\"#newRelationshipForm\").remove();\r\n\t\t\t}, 1000);\r\n\t\t}\r\n\r\n\t\t/* Hide Membership Assignment during Purchase Flow */\r\n\r\n\t\tif ($eSRO.currentScreen == \"membership.aspx\") {\r\n\t\t\t$(\"#ownershipInfo\").remove();\r\n\t\t}\r\n\r\n\t\t/* Prevent Membership Qty during Purchase Flow */\r\n\r\n\t\tif ($eSRO.currentScreen == \"membership.aspx\") {\r\n\t\t\t$(\".pricing .ui-spinner\").remove();\r\n\t\t}\r\n\r\n\t\t/* Membership Exists */\r\n\r\n\t\tif ($eSRO.currentScreen === \"membershipslist.aspx\") {\r\n\t\t\tvar membershipList = $(\"#ctl00_body_MembershipsListCtrl\");\r\n\t\t\tif (\r\n\t\t\t\tmembershipList.children(\".dataItem\").length === 0 ||\r\n\t\t\t\t(membershipList.children(\".dataItem\").length === 1 &&\r\n\t\t\t\t\tmembershipList.find(\r\n\t\t\t\t\t\t'.dataItem.item_background.item_data_background[data-id=\"3aba13d4-f713-ed11-83ae-edffa91b69e3\"], .dataItem.item_background.item_data_background[data-id=\"42cdb2b7-2b64-ee11-8445-82f83f933b5d\"]'\r\n\t\t\t\t\t).length > 0)\r\n\t\t\t) {\r\n\t\t\t\tmembershipList.after(\r\n\t\t\t\t\t'<div class=\"message\">The account you are currently logged in to already has an active All Red membership or Season Ticket. If you would like to purchase for an alternative supporter please sign out and log back in using the account you wish to purchase for.</div>'\r\n\t\t\t\t);\r\n\t\t\t}\r\n\t\t\tif (membershipList.children(\".dataItem\").length === 0) {\r\n\t\t\t\t$(\"#ctl00_body_MembershipsListCtrl\").remove();\r\n\t\t\t}\r\n\t\t}\r\n\r\n\t\t/* Custom Seat Key */\r\n\r\n\t\tif ($eSRO.currentScreen === \"event4.aspx\") {\r\n\t\t\tif ($(\"#eventPage.seated\").length > 0) {\r\n\t\t\t\t$(\"#instructions\").after(\r\n\t\t\t\t\t$(\r\n\t\t\t\t\t\t'<div class=\"legend-container\" id=\"seat-key\"><div class=\"leg\"><div class=\"legend available\"></div><div class=\"description\">Available</div></div><div class=\"leg\"><div class=\"legend unavailable\"></div><div class=\"description\">Unavailable</div></div><div class=\"leg\"><div class=\"legend your-selection\"></div><div class=\"description\">Your Selection</div></div><div class=\"leg\"><div class=\"legend restricted-view\"></div><div class=\"description\">Restricted View</div></div><div class=\"leg\"><div class=\"legend s-restricted-view\"></div><div class=\"description\">Severely Restricted View</div></div><div class=\"leg\"><div class=\"legend wheelchair-bay\"></div><div class=\"description\">Wheelchair Bay</div></div><div class=\"leg\"><div class=\"legend wheelchair-pa-seat\"></div><div class=\"description\">Personal Assistant</div></div><div class=\"leg\"><div class=\"legend ambulant\"></div><div class=\"description\">Ambulant</div></div><div class=\"leg\"><div class=\"legend wheelchair-pa\"></div><div class=\"description\">Indicates Wheelchair and PA pair</div></div><div class=\"leg\"><div class=\"legend ST-TEX-SEAT\"></div><div class=\"description\">Season Ticket Seat</div></div><div class=\"leg\"><div class=\"legend ST-WC-TEX-SEAT\"></div><div class=\"description\">Season Ticket WC Bay</div></div><div class=\"leg\"><div class=\"legend ST-WCPA-TEX-SEAT\"></div><div class=\"description\">Season Ticket PA Seat</div></div><div class=\"leg\"><div class=\"legend hospitality-alt-seat\"></div><div class=\"description\">Hospitality Seat</div></div><div class=\"leg\"><div class=\"legend hosp-season-ticket-seat\"></div><div class=\"description\">Hospitality Season Ticket Seat</div></div><div class=\"leg\"><div class=\"legend safe-standing\"></div><div class=\"description\">Safe Standing</div></div></div>'\r\n\t\t\t\t\t)\r\n\t\t\t\t);\r\n\t\t\t}\r\n\t\t}\r\n\r\n\t\t/* Register Error Message */\r\n\r\n\t\tif (window.location.href.indexOf(\"/crmcreateaccount.aspx\") > -1) {\r\n\t\t\tconsole.log(\"create account\");\r\n\t\t\t$(\"#PH_Errors .pageSectionTitle\").text(function (i, oldText) {\r\n\t\t\t\treturn oldText === \"Error\" ? \"Please note\" : oldText;\r\n\t\t\t});\r\n\t\t\t$(\"#PH_Errors #bottomButtonsBar\").before(\r\n\t\t\t\t\"<p style='padding: .5em 0; margin:0;'>An account with some of these details already exists. Please click 'Back' and try again.</p>\"\r\n\t\t\t);\r\n\t\t\t$(\"#PH_Errors .small_text_b\").hide();\r\n\t\t}\r\n\r\n\t\t/* Load to Card placeholder */\r\n\r\n\t\tif ($eSRO.currentScreen === \"delivery.aspx\" || $eSRO.currentScreen === \"order.aspx\") {\r\n\t\t\tvar functionCounter = setInterval(function () {\r\n\t\t\t\t$(\"#ticketCollectionForm .ui-autocomplete-input:not(.defaulted)\").each(function () {\r\n\t\t\t\t\t$(this).addClass(\"defaulted\");\r\n\t\t\t\t\t$(this).attr(\"placeholder\", \"Select from Dropdown\");\r\n\t\t\t\t});\r\n\t\t\t}, 100);\r\n\t\t}\r\n\r\n\t\t/* Highlight Subscriber Ticket */\r\n\r\n\t\tvar STSTATUSMSG =\r\n\t\t\t' <span class=\"desktop\"><b title=\"Season Ticket Seat - this seat does not carry a credit\" style=\"cursor: pointer;\">[Season Ticket Seat - this seat does not carry a credit]</b></span> <span class=\"mobile\" style=\"display:none;\"><b title=\"Season Ticket Seat - this seat does not carry a credit\" style=\"cursor: pointer;\">[Season Ticket Seat - this seat does not carry a credit]</b></span>';\r\n\t\tvar NCSTATUSMSG =\r\n\t\t\t' <span class=\"desktop\"><b title=\"Not Attended - this seat does not carry a credit\" style=\"cursor: pointer;\">[Not Attended - this seat does not carry a credit]</b></span><span class=\"mobile\" style=\"display:none;\"><b title=\"Not Attended - this seat does not carry a credit\" style=\"cursor: pointer;\">[Not Attended - this seat does not carry a credit]</b></span>';\r\n\r\n\t\tif ($eSRO.currentScreen == \"crmdetails.aspx\") {\r\n\t\t\tvar subCounter = setInterval(function () {\r\n\t\t\t\t$(\".spScreen tr:not(.st-checked)\").each(function () {\r\n\t\t\t\t\tvar eventString = $(this).children(\".ShowName\").children(\".dataField\").text().replace(/\\s/g, \"\");\r\n\t\t\t\t\teventString = eventString.replace(\"&\", \"-\");\r\n\t\t\t\t\tif ($(\"body\").hasClass(\"client-has-type-\" + eventString + \"-STSeat\")) {\r\n\t\t\t\t\t\tif ($(this).children(\".Owner\").children(\".dataField\").text() == $(\".greeting\").text()) {\r\n\t\t\t\t\t\t\t$(this).children(\".ShowName\").append(STSTATUSMSG);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t} else if ($(\"body\").hasClass(\"client-has-type-\" + eventString + \"-NoCredit\")) {\r\n\t\t\t\t\t\tif ($(this).children(\".Owner\").children(\".dataField\").text() == $(\".greeting\").text()) {\r\n\t\t\t\t\t\t\t$(this).children(\".ShowName\").append(NCSTATUSMSG);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\t$(this)\r\n\t\t\t\t\t\t\t.children(\".StatusIcons\")\r\n\t\t\t\t\t\t\t.children(\"img\")\r\n\t\t\t\t\t\t\t.each(function () {\r\n\t\t\t\t\t\t\t\tif ($(this).attr(\"title\") == \"Season Ticket\") {\r\n\t\t\t\t\t\t\t\t\t$(this).parent().parent().addClass(\"subscriber-ticket\");\r\n\t\t\t\t\t\t\t\t\t$(this).parent().parent().children(\".ShowName\").append(STSTATUSMSG);\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t});\r\n\t\t\t\t\t}\r\n\t\t\t\t\t$(this).addClass(\"st-checked\");\r\n\t\t\t\t});\r\n\t\t\t}, 100);\r\n\t\t}\r\n\r\n\t\t$(\r\n\t\t\t'.screen-ballotapplication_aspx .priceType .name span:contains(\"Disabled\"), .screen-ballotapplication_aspx .priceType .name span:contains(\"PA\")'\r\n\t\t)\r\n\t\t\t.parent()\r\n\t\t\t.parent()\r\n\t\t\t.addClass(\"disabled\");\r\n\r\n\t\t/* Simple Extra Data Form */\r\n\r\n\t\t$(\"body\").on(\"dialogopen\", function (e) {\r\n\t\t\tif (e.target.id === \"itemsExtraDataDialog\") {\r\n\t\t\t\tif ($('#itemsExtraDataDialog .form-container[data-formid=\"ExtraData_CustomForm7\"]').length > 0) {\r\n\t\t\t\t\t$(\"#itemsExtraDataDialog\").parent().addClass(\"simpleForm\");\r\n\t\t\t\t\t$(\".simpleForm .ui-dialog-titlebar .ui-dialog-title\").prependTo($(\".simpleForm #itemsExtraDataPanel\"));\r\n\r\n\t\t\t\t\tvar simpleCounter = setInterval(function () {\r\n\t\t\t\t\t\tif ($(\".basketManRow.missing\").length > 0) {\r\n\t\t\t\t\t\t\t$(\"input.mandatory\").click();\r\n\t\t\t\t\t\t\t$(\"#btnNext\").click();\r\n\t\t\t\t\t\t\tapplyCheck = 1;\r\n\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\tclearInterval(simpleCounter);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}, 10);\r\n\t\t\t\t} else {\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\t\t\r\n\t\t\r\n\t\t$(\"body\").on(\"dialogopen\", function (e) {\r\n\t\t\tif (e.target.id === \"itemsExtraDataDialog\") {\r\n\t\t\t\tif ($('#itemsExtraDataDialog .form-container[data-formid=\"ExtraData_CustomForm3\"]').length > 0) {\r\n\t\t\t\t\t$(\"#itemsExtraDataDialog\").parent().addClass(\"simpleForm\");\r\n\t\t\t\t\t$(\".simpleForm .ui-dialog-titlebar .ui-dialog-title\").prependTo($(\".simpleForm #itemsExtraDataPanel\"));\r\n\r\n\t\t\t\t\tvar simpleCounter = setInterval(function () {\r\n\t\t\t\t\t\tif ($(\".basketManRow.missing\").length > 0) {\r\n\t\t\t\t\t\t\t$(\"input.mandatory\").click();\r\n\t\t\t\t\t\t\t$(\"#btnNext\").click();\r\n\t\t\t\t\t\t\tapplyCheck = 1;\r\n\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\tclearInterval(simpleCounter);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}, 10);\r\n\t\t\t\t} else {\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\t\t\r\n\t\t\r\n\t\t$(\"body\").on(\"dia