            "text": "/* Scroll Position */\n$(window).scroll(function () {\n\tif ($(window).scrollTop() >= 50) {\n\t\t$(\"body\").addClass(\"fifty\");\n\t}\n\tif ($(window).scrollTop() >= 45) {\n\t\t$(\"body\").addClass(\"fortyfive\");\n\t} else {\n\t\t$(\"body\").removeClass(\"fortyfive\");\n\t\t$(\"body\").removeClass(\"fifty\");\n\t}\n});\n\n/* Comparison Chart */\n$(\".comparison-chart ul\").on(\"click\", \"li\", function () {\n\tvar pos = $(this).index() + 2;\n\t$(\".comparison-chart tr\").find(\"td:not(:eq(0))\").hide();\n\t$(\".comparison-chart td:nth-child(\" + pos + \")\").css(\"display\", \"table-cell\");\n\t$(\".comparison-chart tr\").find(\"th:not(:eq(0))\").hide();\n\t$(\".comparison-chart li\").removeClass(\"active\");\n\t$(this).addClass(\"active\");\n});\n\nvar mediaQuery = window.matchMedia(\"(min-width: 781px)\");\nmediaQuery.addListener(compChart);\n\ncompChart(mediaQuery);\n\n/* More Info Collapsable Dropdown */\nvar coll = document.getElementsByClassName(\"collapsible\");\nvar i;\n\nfor (i = 0; i < coll.length; i++) {\n\tcoll[i].addEventListener(\"click\", function () {\n\t\tthis.classList.toggle(\"active\");\n\t\tvar content = this.nextElementSibling;\n\t\tif (content.style.display === \"block\") {\n\t\t\tcontent.style.display = \"none\";\n\t\t} else {\n\t\t\tcontent.style.display = \"block\";\n\t\t}\n\t});\n}\n\n/* Product Info */\n\n$(document).ready(function () {\n\tif ($eSRO.currentScreen === \"membership.aspx\" || $eSRO.currentScreen === \"giftvoucher.aspx\") {\n\t\tvar contentTitle = $(\".productName\").text();\n\t\tvar contentDesc = $(\".productDescription\").text();\n\t\tvar contentWrapper = $(\n\t\t\t'<div class=\"content-wrapper title\"><div class=\"content\"><h1>' + contentTitle + \"</h1><p>\" + contentDesc + \"</p></div></div>\"\n\t\t);\n\t\tcontentWrapper.prependTo(\"#genrehtml\");\n\t\tif (contentTitle.indexOf(\"Wait\") >= 0) {\n\t\t\t//$(\"h2.general_caption\").hide();\n\t\t\t$(\"h2.general_caption\").text(\"Select Waiting List\");\n\t\t}\n\t} else if ($eSRO.currentScreen === \"donation.aspx\") {\n\t\tvar contentTitle = $(\".productData h1\").text();\n\t\tvar contentDesc = $(\".productData p\").text();\n\t\tvar contentWrapper = $(\n\t\t\t'<div class=\"content-wrapper title\"><div class=\"content\"><h1>' + contentTitle + \"</h1><p>\" + contentDesc + \"</p></div></div>\"\n\t\t);\n\t\tcontentWrapper.prependTo(\"#genrehtml\");\n\t} else if ($eSRO.currentScreen === \"merchandise.aspx\") {\n\t\tvar contentTitle = $(\".productInfo h1\").text();\n\t\tvar contentDesc = $(\"div.productBriefDescription\").text();\n\t\tvar contentWrapper = $(\n\t\t\t'<div class=\"content-wrapper title\"><div class=\"content\"><h1>' + contentTitle + \"</h1><p>\" + contentDesc + \"</p></div></div>\"\n\t\t);\n\t\tcontentWrapper.prependTo(\"#genrehtml\");\n\t\tvar Counter = setInterval(function () {\n\t\t\tif ($(\".mediaContainer .mediaList img\").length > 0) {\n\t\t\t\t$(\".mediaContainer\").appendTo(\".content\");\n\t\t\t\t$(\".mediaContainer\").insertAfter(\".content h1\");\n\t\t\t}\n\t\t}, 100);\n\t}\n});\n\n/* Direct Click to Basket */\n$(\"#my_basket\").attr(\"href\", \"order.aspx\");\n\n$(\"#my_basket\").on(\"click\", function (e) {\n\twindow.location = \"order.aspx\";\n});\n\n/* Device Landscape */\nviewport = document.querySelector(\"meta[name=viewport]\");\nif (window.orientation == 0) {\n\tviewport.setAttribute(\"content\", \"width=device-width, maximum-scale=1.0\");\n} else {\n\tviewport.setAttribute(\"content\", \"width=device-width, initial-scale=0.5, maximum-scale=1.0\");\n}\n\n$(window).on(\"orientationchange\", function (event) {\n\tviewport = document.querySelector(\"meta[name=viewport]\");\n\tif (window.orientation == 0) {\n\t\tviewport.setAttribute(\"content\", \"width=device-width, maximum-scale=1.0\");\n\t} else {\n\t\tviewport.setAttribute(\"content\", \"width=device-width, initial-scale=0.5, maximum-scale=1.0\");\n\t}\n});\n\n/* Basket Errors & Text Changes */\nif ($eSRO.currentScreen === \"order.aspx\") {\n\tvar basketCounter = setInterval(function () {\n\t\t/* Basket Error */\n\t\tif ($(\".basketItem.has-basket-warning\").length > 0) {\n\t\t\t$(\".basketItem.has-basket-warning:not(.error-is-displayed)\").each(function () {\n\t\t\t\t//if ($(this).children('.basket-warning').attr(\"title\") !== undefined){\n\t\t\t\tif ($(this).children(\".basket-warning\").attr(\"aria-label\") !== undefined) {\n\t\t\t\t\tvar error = $('<div class=\"error-to-display\">' + $(this).children(\".basket-warning\").attr(\"aria-label\") + \"</div>\");\n\t\t\t\t\tvar errorReplaced = $(\n\t\t\t\t\t\t'<div class=\"error-to-display\">' +\n\t\t\t\t\t\t\terror.html().replace(\"There is a problem with this item:\", \"\").replace(\"'\", \"\").replace(\" '\", \"\") +\n\t\t\t\t\t\t\t\"</div>\"\n\t\t\t\t\t);\n\t\t\t\t\t$(this).children(\".basket-warning\").html(errorReplaced);\n\t\t\t\t\t$(this).children(\".basket-warning\").attr(\"title\", \"\");\n\t\t\t\t\t$(this).addClass(\"error-is-displayed\");\n\t\t\t\t}\n\t\t\t});\n\t\t} else if ($(\".exchangeBasketSection\").length > 0) {\n\t\t\t$(\".exchangeBasketSection\").each(function () {\n\t\t\t\t$(\".buttonExplain\").show();\n\t\t\t});\n\t\t}\n\t\t/* Basket Parking Text Change */\n\t\tif ($(\".basketArea\").length > 0) {\n\t\t\t$(\".basketArea\").each(function () {\n\t\t\t\tif ($(this).is(':contains(\"Car Park\")')) {\n\t\t\t\t\t$(this)\n\t\t\t\t\t\t.children(\".basketTickets\")\n\t\t\t\t\t\t.children(\".basketItem\")\n\t\t\t\t\t\t.each(function () {\n\t\t\t\t\t\t\t$(this).children(\".basketProperty.Details\").text(\"Qty: 1 Space\");\n\t\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t}, 1000);\n}\n\n/* Ticket Schemes Terms */\nif ($eSRO.currentScreen === \"offers.aspx\") {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\".ticketSchemes-container\").length > 0 && applyCheck == 0) {\n\t\t\tfunction loadPage(href) {\n\t\t\t\tvar xmlhttp = new XMLHttpRequest();\n\t\t\t\txmlhttp.open(\"GET\", href, false);\n\t\t\t\txmlhttp.send();\n\t\t\t\treturn xmlhttp.responseText;\n\t\t\t}\n\t\t\tvar folders = window.location.pathname;\n\t\t\tvar lastSegment = folders.split(\"/\").pop();\n\t\t\tvar pathToLoad =\n\t\t\t\tlocation.protocol + \"//\" + window.location.host + \"/usercontent/documents\" + $eSRO.siteBasePath + \"html/ticketschemes-terms.html\";\n\t\t\t$.ajax({\n\t\t\t\turl: pathToLoad,\n\t\t\t\ttype: \"HEAD\",\n\t\t\t\tsuccess: function () {\n\t\t\t\t\tdocument.getElementById(\"genrehtml\").innerHTML = '<div id=\"genrehtmlterms\">' + loadPage(pathToLoad) + \"</div>\";\n\t\t\t\t},\n\t\t\t});\n\t\t\tapplyCheck = 1;\n\t\t}\n\t}, 1000);\n}\n\n/* CRM User Account Image */\nif ($eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#crmMyProfileContent .ClientImageUrl\").length > 0) {\n\t\t\tif ($(\"#crmMyProfileContent .ClientImageUrl img\").attr(\"src\").indexOf(\"1206.png\") != -1) {\n\t\t\t\t$(\"#crmMyProfileContent .ClientImageUrl img\").attr(\"src\", \"/cus/beta/css/core/images/user.png\");\n\t\t\t}\n\t\t\t$(\"#crmMyProfileContent .ClientImageUrl\").show();\n\t\t}\n\t}, 100);\n}\n\n/* Delivery Details */\nif ($eSRO.currentScreen === \"delivery.aspx\" || $eSRO.currentScreen === \"order.aspx\") {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#chkShowTicketCollection\").length > 0 && $(\"#chkShowTicketCollection\").prop(\"checked\") == false) {\n\t\t\t$(\"#chkShowTicketCollection\").click();\n\t\t\t$(\"#chkShowTicketCollection\").attr(\"disabled\", true);\n\t\t\tapplyCheck = 1;\n\t\t}\n\t\tif (applyCheck == 1 && !$(\"body\").hasClass(\"forceCheck\")) {\n\t\t\t$(\"body\").addClass(\"forceCheck\");\n\t\t}\n\t\t//$(\".tmp-disabled\").attr(\"disabled\", false).click();\n\t}, 1000);\n}\n\n/* Remove Strong Relationship Roles */\nif ($eSRO.currentScreen === \"order.aspx\" || $eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar modalCounter = setInterval(function () {\n\t\tif ($(\".myDialog\").dialog(\"isOpen\")) {\n\t\t\t$(\".relationshipType\").on(\"change\", function () {\n\t\t\t\tif ($(this).val() == \"30000000-0000-0000-0000-000000000001\" || $(\".relationshipType option:selected\").text() == \"Strong Relationship\") {\n\t\t\t\t\tconsole.log(\"strong\");\n\t\t\t\t\t$(\".relationshipRole\").attr(\"style\", \"display:none !important\");\n\t\t\t\t} else {\n\t\t\t\t\tconsole.log(\"standard\");\n\t\t\t\t\t$(\".relationshipRole\").attr(\"style\", \"display:block !important\");\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t}, 1000);\n}\n\n/* Add Hospitality Class */\nif (window.location.href.indexOf(\"hospitality\") > -1) {\n\t$(\"body\").addClass(\"hospitality\");\n}\n\n/* Back to Hospitality Packages */\nif ($eSRO.currentScreen === \"event4.aspx\") {\n\tvar hospBtn = $(\"body.hospitality .magnify\");\n\tvar link = window.location.href.substring(window.location.href, window.location.href.lastIndexOf(\"/\"));\n\tif (hospBtn.length > 0) {\n\t\t//hospBtn.text('Back to Package Selection');\n\t\thospBtn.attr({\n\t\t\tonclick: 'location.href=\"' + link + '\";',\n\t\t\ttitle: \"Back to Package Selection\",\n\t\t\t\"aria-label\": \"Back to Package Selection\",\n\t\t});\n\t}\n}\n\n/* Disabled Fields Fix */\nsetTimeout(function () {\n\tif ($eSRO.currentScreen == \"delivery.aspx\") {\n\t\tif (document.getElementById(\"fldDeliveryAddress\") && document.getElementById(\"fldDeliveryAddress\").disabled) {\n\t\t\tdocument.getElementById(\"fldDeliveryAddress\").disabled = false;\n\t\t}\n\t\tif (document.getElementById(\"fldDeliveryAddress2\") && document.getElementById(\"fldDeliveryAddress2\").disabled) {\n\t\t\tdocument.getElementById(\"fldDeliveryAddress2\").disabled = false;\n\t\t}\n\t\tif (\n\t\t\tdocument.querySelector(\"#frmDlg div.row.DropDown.DeliveryCountryIdOrName span > input\") &&\n\t\t\tdocument.querySelector(\"#frmDlg div.row.DropDown.DeliveryCountryIdOrName span > input\").disabled\n\t\t) {\n\t\t\tdocument.querySelector(\"#frmDlg div.row.DropDown.DeliveryCountryIdOrName span > input\").disabled = false;\n\t\t}\n\t\tif (\n\t\t\tdocument.querySelector(\"#frmDlg > div > div > fieldset > div > div.row.DropDown.DeliveryCityIdOrName > div.field > span > input\") &&\n\t\t\tdocument.querySelector(\"#frmDlg > div > div > fieldset > div > div.row.DropDown.DeliveryCityIdOrName > div.field > span > input\").disabled\n\t\t) {\n\t\t\tdocument.querySelector(\n\t\t\t\t\"#frmDlg > div > div > fieldset > div > div.row.DropDown.DeliveryCityIdOrName > div.field > span > input\"\n\t\t\t).disabled = false;\n\t\t}\n\t\tif (document.getElementById(\"fldDeliveryZipCode\") && document.getElementById(\"fldDeliveryZipCode\").disabled) {\n\t\t\tdocument.getElementById(\"fldDeliveryZipCode\").disabled = false;\n\t\t}\n\t}\n}, 750);\n\n/* Ballots Info Info */\nif ($eSRO.currentScreen === \"ballotapplication.aspx\") {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#ctl00_body_ContentCtrl.editing\").length > 0 && applyCheck != 1) {\n\t\t\tvar contentTitle = $(\".event.active > .name\").text();\n\t\t\tvar contentDesc = $(\".event.active .date\").text();\n\t\t\tvar contentWrapper = $(\n\t\t\t\t'<div class=\"content-wrapper title\"><div class=\"content\"><h1>' + contentTitle + \"</h1><p>\" + contentDesc + \"</p></div></div>\"\n\t\t\t);\n\t\t\tcontentWrapper.prependTo(\"#genrehtml\");\n\t\t\tapplyCheck = 1;\n\t\t} else if ($(\"#ctl00_body_ContentCtrl.editing\").length < 1 && applyCheck != 0) {\n\t\t\t$(\".content-wrapper\").remove();\n\t\t\tapplyCheck = 0;\n\t\t}\n\t}, 100);\n}\n\n/* Ballots Continue Button */\nvar applyCheckN2 = 0;\nvar functionCounter = setInterval(function () {\n\tif ($eSRO.currentScreen === \"ballotapplication.aspx\" && $(\".content.confirming\").length && applyCheckN2 != 1) {\n\t\tapplyCheckN2 = 1;\n\t\t$('<div class=\"confirmation\"><p><a href=\"/\" class=\"landing-button secondary\">Continue Shopping</a></p></div>').insertAfter(\".confirmation\");\n\t}\n}, 100);\n\n/* dialog fix */\nif ($eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar Counter = setInterval(function () {\n\t\t$(\".ui-dialog\").each(function () {\n\t\t\tif (parseInt($(this).css(\"top\"), 10) < 0) {\n\t\t\t\tvar scrollDistance = $(document).scrollTop();\n\t\t\t\tvar windowHeight = $(window).height();\n\t\t\t\tvar dialogHeight = $(\".ui-dialog\").height();\n\t\t\t\tvar topPosition = windowHeight / 2 - dialogHeight / 2 + scrollDistance;\n\t\t\t\tif (topPosition < 0) {\n\t\t\t\t\t$(this).css(\"top\", \"0px\");\n\t\t\t\t} else if (windowHeight < dialogHeight) {\n\t\t\t\t\t$(this).css(\"top\", \"0px\");\n\t\t\t\t} else {\n\t\t\t\t\t$(this).css(\"top\", topPosition);\n\t\t\t\t}\n\t\t\t}\n\t\t});\n\t}, 100);\n}\n\n/* Accordion */\nif ($eSRO.currentScreen === \"screenloader.aspx\") {\n\tvar coll = document.getElementsByClassName(\"collapsible\");\n\tvar i;\n\n\tfor (i = 0; i < coll.length; i++) {\n\t\tcoll[i].addEventListener(\"click\", function () {\n\t\t\tthis.classList.toggle(\"active\");\n\t\t\tvar content = this.nextElementSibling;\n\t\t\tif (content.style.maxHeight === \"none\") {\n\t\t\t\tcontent.style.maxHeight = \"0\";\n\t\t\t} else {\n\t\t\t\tcontent.style.maxHeight = \"none\";\n\t\t\t}\n\t\t});\n\t}\n}\n\n/* Forwarding - Remove Blank Options */\n$(\"body\").on(\"dialogopen\", \".ownerSelectionDialog\", function () {\n\tvar checkExist = setInterval(function () {\n\t\tif ($(\"#cmbSelectPriceType\").length) {\n\t\t\t$(\".ownerSelectionDialog select option\")\n\t\t\t\t.filter(function () {\n\t\t\t\t\treturn !this.value || $.trim(this.value).length == 0 || $.trim(this.text).length == 0;\n\t\t\t\t})\n\t\t\t\t.remove();\n\t\t\t//clearInterval(checkExist);\n\t\t\t$(\".ownerSelectionDialog .ui-dialog-buttonset button:not(.defaulted)\").removeClass(\"ui-button-disabled\");\n\t\t\t$(\".ownerSelectionDialog .ui-dialog-buttonset button:not(.defaulted)\").removeClass(\"ui-state-disabled\");\n\t\t\t$(\".ownerSelectionDialog .ui-dialog-buttonset button:not(.defaulted)\").prop(\"disabled\", false);\n\t\t\t$(\".ownerSelectionDialog .ui-dialog-buttonset button:not(.defaulted)\").addClass(\"defaulted\");\n\t\t}\n\t}, 100);\n});\n\n/* Ticket Turnback Fix */\nif ($eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar applyCheck = 0;\n\tvar errorMessage =\n\t\t\"You cannot donate this ticket.  Only Home Match Tickets can be donated and the purchaser listed in the tickets screen will need to log-in to their account to complete this donation.\";\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#BizAction\\\\$Donation\\\\.PerformTicketTurnback\").length > 0 && applyCheck != 1) {\n\t\t\t$(\"#BizAction\\\\$Donation\\\\.PerformTicketTurnback:empty\").after('<div class=\"ui-dialog-buttonpane\"></div>');\n\t\t\t$(\"#BizAction\\\\$Donation\\\\.PerformTicketTurnback:empty\").prepend(\n\t\t\t\t'<div class=\"crm_screen_container\"><div class=\"spScreen\"><div class=\"header\"><h1>DONATING TICKETS</h1><h2>' +\n\t\t\t\t\terrorMessage +\n\t\t\t\t\t\"</h2></div></div></div>\"\n\t\t\t);\n\t\t\tapplyCheck = 1;\n\t\t} else if ($(\"#BizAction\\\\$Donation\\\\.PerformTicketTurnback\").length < 1 && applyCheck != 0) {\n\t\t\tapplyCheck = 0;\n\t\t}\n\t}, 100);\n}\n\n/* Mandatory Ticket Schemes By Name */\nif ($eSRO.currentScreen === \"offers.aspx\" || $eSRO.currentScreen === \"order.aspx\") {\n\tvar functionCounter = setInterval(function () {\n\t\t$(\"#TicketSchemeSelections tbody tr\").each(function () {\n\t\t\tif ($(this).is(':contains(\"Mandatory\")')) {\n\t\t\t\tif ($(this).children(\"td\").children('input[type=\"checkbox\"]').length > 0) {\n\t\t\t\t\tif ($(this).children(\"td\").children('input[type=\"checkbox\"]').prop(\"checked\") == false) {\n\t\t\t\t\t\t$(this).children(\"td\").children('input[type=\"checkbox\"]').click();\n\t\t\t\t\t}\n\t\t\t\t\t$(this).children(\"td\").children('input[type=\"checkbox\"]').attr(\"disabled\", true);\n\t\t\t\t}\n\t\t\t\tclearInterval(functionCounter);\n\t\t\t\tif (!$(\"body\").hasClass(\"mandatoryTicketSchemes\")) {\n\t\t\t\t\t$(\"body\").addClass(\"mandatoryTicketSchemes\");\n\t\t\t\t}\n\t\t\t}\n\t\t});\n\t}, 1000);\n}\n\n/* View from Seat */\nif ($eSRO.currentScreen === \"event4.aspx\") {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#dvmContainer\").length > 0 && applyCheck != 1) {\n\t\t\t$(\"#dvmContainer\").prependTo(\"#ticketsPane\");\n\t\t\tapplyCheck = 1;\n\t\t}\n\t}, 100);\n}\n\n/* Add Class for available hospitality packages */\nif ($eSRO.currentScreen === \"hospitalityevent.aspx\") {\n\t$(\".dataItem\").each(function () {\n\t\tif (!$(this).children(\".itemsButtonsContainer\").children(\".button\").is(\".disabled\")) {\n\t\t\t$(this).addClass(\"available\");\n\t\t}\n\t});\n}\n\n/* Hide Ballots Owners List when only one ticket is selected */\nif ($eSRO.currentScreen === \"ballotapplication.aspx\") {\n\thideownerslist();\n\t$(\".input-tickets\").on(\"input\", function () {\n\t\thideownerslist();\n\t});\n\t$(\".ui-spinner-button\").on(\"click\", function () {\n\t\thideownerslist();\n\t});\n}\n\n/* eCRM Scroll Fix */\n$(\"#leftMenu\").on(\"tabsactivate\", () => {\n\tsetTimeout(() => {\n\t\twindow.scrollTo(0, 0);\n\t}, 1);\n});\n\n/* eCRM Tickets Checkbox */\nvar waitForScreenPart = setInterval(() => {\n\tif ($(\"#PH_CRM_details_page\").length > 0) {\n\t\tclearInterval(waitForScreenPart);\n\t\tticketEvents();\n\t}\n}, 100);\n\nfunction ticketEvents() {\n\t$(\"#PH_CRM_details_page\").on(\"click\", \".crm_screen_container .spScreenContent table tbody tr\", function (e) {\n\t\t$(this).addClass(\"unset\");\n\t\t$(this).children(\".crm_grid_selector\").children(\"input\").click();\n\t\tif ($(this).hasClass(\"unset\")) {\n\t\t\tif ($(this).hasClass(\"expanded\")) {\n\t\t\t\t$(this).removeClass(\"expanded\");\n\t\t\t\t$(this).removeClass(\"unset\");\n\t\t\t} else {\n\t\t\t\t$(this).addClass(\"expanded\");\n\t\t\t\t$(this).removeClass(\"unset\");\n\t\t\t}\n\t\t}\n\t\tif ($(this).children(\".crm_grid_selector\").children(\"input\").is(\":checked\")) {\n\t\t\t$(this).addClass(\"active\");\n\t\t} else {\n\t\t\t$(this).removeClass(\"active\");\n\t\t}\n\t});\n}\n\n/* Spreedly */\nif ($(\"#sgs-payment-form\")) {\n\t$('.sgs-form-h2:contains(\"Billing Address\")').hide();\n\t$(\".sgs-field-fullname > label\").text(\"Cardholder Name\");\n\t$(\".sgs-field-email > label\").text(\"Email\");\n\t$(\".sgs-field-phone > label\").text(\"Phone Number\");\n\t$(\"#spreedly-number-label\").text(\"CVV/CVC/CID\");\n\t$(\"label.sgs-field-group.sgs-number\").text(\"Credit/Debit Card Number\");\n\t$(\".sgs-field-submit\").css(\"order\", \"99\");\n\n\tif ($(\"#sgs-payment-form > fieldset.sgs-fs-cc #sgs_ga_pay\")) {\n\t\t$(\"#sgs_ga_pay\").parent().css(\"order\", \"1\");\n\t\t$(\".sgs-fs-name\").css(\"order\", \"2\");\n\t\t$('.sgs-form-h2:contains(\"Billing Address\")').css(\"order\", \"3\");\n\t\t$(\".sgs-fs-address\").css(\"order\", \"4\");\n\t\t$(\"#spreedly-number\").parent().parent().css(\"order\", \"5\");\n\n\t\tvar paymentCounter = setInterval(function () {\n\t\t\tif ($(\".sgs-form-h2:nth-of-type(3):not(.set)\") && $(\"#sgs_cc_pay\").prop(\"checked\") == false) {\n\t\t\t\t$(\"#sgs_cc_pay\").click();\n\t\t\t\t$(\"#sgs_cc_pay\").hide();\n\t\t\t\t$(\".sgs-form-h2:nth-of-type(3)\").text(\"Pay with Credit/Debit Card\");\n\t\t\t\t$(\".sgs-form-h2:nth-of-type(3)\").addClass(\"set\");\n\t\t\t}\n\t\t}, 1000);\n\t}\n\n\tif (!$(\"#sgs-payment-form > fieldset.sgs-fs-cc #sgs_ga_pay\")) {\n\t\t$(\"#spreedly-number\").parent().parent().css(\"order\", \"2\");\n\t\t$(\".sgs-fs-name\").css(\"order\", \"1\");\n\t}\n}\n\n/* Tool Tips we want to show */\n$(window).bind(\"load\", function () {\n\t$(\".StatusIcons > *\").hover(\n\t\tfunction (e) {\n\t\t\t$(\"body\").addClass(\"show-tooltip\");\n\t\t}, // over\n\t\tfunction (e) {\n\t\t\t$(\"body\").removeClass(\"show-tooltip\");\n\t\t}\n\t);\n});\n\n/* Sticky Basket Timer */\n$(document).ready(function () {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\"#siteMenuBar #CountDown.active\").length && applyCheck != 1) {\n\t\t\tapplyCheck = 1;\n\t\t\t$('<a href=\"/order.aspx\">Go to basket</a>').insertAfter(\"#siteMenuBar #CountDown.active .idCountDown\");\n\t\t}\n\t}, 100);\n});\n\n$(document).ready(function () {\n\tvar applyCheck = 0;\n\tvar functionCounter = setInterval(function () {\n\t\tif ($(\".basketHasItems\").length) {\n\t\t\t$(\"body\").addClass(\"basketHasItems\");\n\t\t} else {\n\t\t\t$(\"body\").removeClass(\"basketHasItems\");\n\t\t}\n\t}, 100);\n});\n\n/* Relocate Seat */\nif ($eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar selectedArea = \"\";\n\tvar Counter = setInterval(function () {\n\t\tif ($(\".replaceSubsTickets\").length > 0) {\n\t\t\tif (selectedArea != $(\"#selectedAreaInfo .selected .area-info-container > .name\").text()) {\n\t\t\t\t$(\"body\").removeClass(\"show-relocate-seats-map\");\n\t\t\t\tselectedArea = $(\"#selectedAreaInfo .selected .area-info-container > .name\").text();\n\t\t\t}\n\t\t}\n\n\t\tif ($(\".replaceSubsTickets\").length > 0 && !$(\".show-relocate-seats-map-button\").length > 0) {\n\t\t\t$(\".areaSelectorContainer\").append(\n\t\t\t\t\"<a onclick=\\\"$('body').addClass('show-relocate-seats-map');\\\" class=\\\"show-relocate-seats-map-button landing-button secondary\\\">Show Stadium Map</a>\"\n\t\t\t);\n\t\t\t$(\".areaSelectorContainer\").append(\n\t\t\t\t\"<a onclick=\\\"$('body').removeClass('show-relocate-seats-map');\\\" class=\\\"hide-relocate-seats-map-button landing-button secondary\\\">Hide Stadium Map</a>\"\n\t\t\t);\n\t\t}\n\n\t\tif ($(\".show-relocate-seats-map\").length > 0) {\n\t\t\t$(\".show-relocate-seats-map-button\").hide();\n\t\t\t$(\".hide-relocate-seats-map-button\").show();\n\t\t} else {\n\t\t\t$(\".show-relocate-seats-map-button\").show();\n\t\t\t$(\".hide-relocate-seats-map-button\").hide();\n\t\t}\n\t}, 10);\n}\n\n/* eCRM Welcome Panels Location */\nif ($eSRO.currentScreen === \"crmdetails.aspx\") {\n\tvar Counter = setInterval(function () {\n\t\t$(\"#crmWelcomeRight > div\").appendTo(\"#crmWelcomeLeft\");\n\t}, 10);\n}\n\n/* Membership Image */\nif ($eSRO.currentScreen === \"membership.aspx\" || $eSRO.currentScreen === \"giftvoucher.aspx\") {\n\tvar Counter = setInterval(function () {\n\t\t$(\".description > .item_image\").insertAfter(\".content > h1\");\n\t}, 10);\n} else if ($eSRO.currentScreen === \"donation.aspx\") {\n\tvar Counter = setInterval(function () {\n\t\t$(\".productData > .item_image\").insertAfter(\".content > h1\");\n\t}, 10);\n}\n\n// Check if the word 'categories' is present in the URL\nif (window.location.href.indexOf(\"categories\") !== -1) {\n\t// Set a cookie that expires in 7 days, storing the current URL\n\tdocument.cookie = \"lastVisitedCategory=\" + encodeURIComponent(window.location.href) + \";path=/; max-age=\" + 60 * 60 * 24 * 7;\n}\n\n// When the 'continue shopping' button is clicked, redirect to the last visited category URL\n$(document).ready(function () {\n\tconsole.log(`last Category Page: ${getLastVisitedCategory()}`);\n\t$(\"#btnContinue\").click(function (e) {\n\t\te.preventDefault();\n\t\tvar url = getLastVisitedCategory();\n\t\tif (url) {\n\t\t\twindow.location.href = url;\n\t\t} else {\n\t\t\t// Redirect to a default URL if no category URL has been visited\n\t\t\twindow.location.href = \"/\";\n\t\t}\n\t});\n});\n\n// sticky toolbar\n/*\nif ($eSRO.currentScreen === \"crmdetails.aspx\" && $(window).width() < 781) {\n\t$(document).ready(function () {\n\t\t$(document).on(\"tabsload\", function (event, ui) {\n\t\t\tif ($(ui.tab[0]).find(\"a#eSRO_Crm_ActiveTickets\").length > 0) setupToolbar();\n\t\t});\n\n\t\tsetupToolbar();\n\n\t\tfunction setupToolbar() {\n\t\t\tvar toolbar = $(\".toolbar\");\n\t\t\tvar startPosition = toolbar.offset().top;\n\t\t\tvar footerPosition = $(\"#PH_CustomFooter\").offset().top;\n\n\t\t\tvar observer = new MutationObserver(function (mutations) {\n\t\t\t\tmutations.forEach(function (mutation) {\n\t\t\t\t\tif (mutation.attributeName === \"class\") {\n\t\t\t\t\t\tupdateButtonVisibility();\n\t\t\t\t\t}\n\t\t\t\t});\n\t\t\t});\n\n\t\t\ttoolbar.find(\"a.button\").each(function () {\n\t\t\t\tobserver.observe(this, {\n\t\t\t\t\tattributes: true,\n\t\t\t\t});\n\t\t\t});\n\n\t\t\t$(window).scroll(function () {\n\t\t\t\tvar scrollPosition = $(window).scrollTop();\n\n\t\t\t\tif (scrollPosition > startPosition) {\n\t\t\t\t\ttoolbar.addClass(\"fixed-buttons\").css(\"top\", \"40px\");\n\t\t\t\t\tupdateButtonVisibility();\n\t\t\t\t} else {\n\t\t\t\t\ttoolbar.removeClass(\"fixed-buttons\").css(\"top\", \"auto\");\n\t\t\t\t\tupdateButtonVisibility();\n\t\t\t\t}\n\n\t\t\t\tif (scrollPosition > footerPosition - $(window).height() - 40) {\n\t\t\t\t\ttoolbar.css(\"top\", \"-100px\");\n\t\t\t\t} else {\n\t\t\t\t\ttoolbar.css(\"top\", \"40px\");\n\t\t\t\t}\n\t\t\t});\n\n\t\t\t// Initial update to make sure the hidden class is applied correctly\n\t\t\tupdateButtonVisibility();\n\n\t\t\tfunction changeText() {\n\t\t\t\ttoolbar.find(\"a.cChangeTicketOwner\").text(\"Forward\");\n\t\t\t\ttoolbar.find(\"a.cTurnback\").text(\"Donate\");\n\t\t\t\ttoolbar.find(\"a.showNfcDetails\").text(\"Download\");\n\t\t\t}\n\n\t\t\tfunction revertText() {\n\t\t\t\ttoolbar.find(\"a.cChangeTicketOwner\").text(\"Forward / Upgrade Ticket\");\n\t\t\t\ttoolbar.find(\"a.cTurnback\").text(\"Donate Ticket\");\n\t\t\t\ttoolbar.find(\"a.showNfcDetails\").text(\"Add to mobile wallet\");\n\t\t\t}\n\n\t\t\tfunction updateButtonVisibility() {\n\t\t\t\tif (toolbar.hasClass(\"fixed-buttons\")) {\n\t\t\t\t\tsetTimeout(function () {\n\t\t\t\t\t\ttoolbar.find(\"a.button.disabled\").addClass(\"hidden\");\n\t\t\t\t\t\ttoolbar.find(\"a.button:not(.disabled)\").removeClass(\"hidden\");\n\t\t\t\t\t\tchangeText();\n\t\t\t\t\t}, 200);\n\t\t\t\t} else {\n\t\t\t\t\ttoolbar.find(\"a.button\").removeClass(\"hidden\");\n\t\t\t\t\trevertText();\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t});\n}\n*/\n\nfunction hideownerslist() {\n\t$(\".priceType\").each(function () {\n\t\tvar str = $(this).children(\".qty\").children(\".static-value\").text().toLowerCase();\n\t\tif (str.indexOf(\"1\") >= 0) {\n\t\t\t$(this).children(\".owners\").children(\".owners-selection\").hide();\n\t\t} else {\n\t\t\t$(this).children(\".owners\").children(\".owners-selection\").show();\n\t\t}\n\t});\n}\n\n// Function to get the last visited category URL\nfunction getLastVisitedCategory() {\n\tvar match = document.cookie.match(new RegExp(\"(^| )\" + \"lastVisitedCategory\" + \"=([^;]+)\"));\n\treturn match ? decodeURIComponent(match[2]) : null;\n}\n\nfunction compChart(mediaQuery) {\n\tif (mediaQuery.matches) {\n\t\t$(\".comparison-chart .sep\").attr(\"colspan\", 4);\n\t\t$(\".comparison-chart .image\").attr(\"colspan\", 1);\n\t\t$(\".comparison-chart .cta\").attr(\"colspan\", 1);\n\t} else {\n\t\t$(\".comparison-chart .sep\").attr(\"colspan\", 2);\n\t\t$(\".comparison-chart .image\").attr(\"colspan\", 2);\n\t\t$(\".comparison-chart .cta\").attr(\"colspan\", 2);\n\t}\n}\n\n/* Create Modal */\nfunction createDialog(title, text) {\n\treturn $(\"<div class='dialog' title='\" + title + \"'><p>\" + text + \"</p></div>\").dialog({\n\t\tresizable: false,\n\t\tminHeight: 400,\n\t\twidth: 600,\n\t\tmodal: true,\n\t\tbuttons: {\n\t\t\tClose: function () {\n\t\t\t\t$(this).dialog(\"close\");\n\t\t\t},\n\t\t\t/* Cancel: function() {\n\t\t  $( this ).dialog( \"close\" );\n\t  }*/\n\t\t},\n\t});\n}\n\nfunction changeRegister() {\n\twindow.location.replace(\"/crmcreateaccount.aspx\");\n}\n\nif ($eSRO.currentScreen === \"order.aspx\") {\n\tsetTimeout(function () {\n\t\tif ($(\".ownerPoints\")) {\n\t\t\t$(\".basketTickets\").addClass(\"owner-points-displayed\");\n\t\t}\n\t}, 300);\n}\n"
